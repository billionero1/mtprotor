# /etc/default/mtprotor

# Path to official Telegram MTProxy binary
MTPROXY_BIN=/usr/local/bin/mtproto-proxy

# Shared args for every worker process.
# Do NOT include -p/-H/-S here; wrapper injects them per worker.
MTPROXY_BASE_ARGS="--aes-pwd /etc/mtprotor/proxy-multi.conf --aes-key /etc/mtprotor/proxy-secret"

# Worker wrapper computes plain port as listen_port + offset.
MTPROXY_PLAIN_PORT_OFFSET=10000

# /etc/default/mtprotor

# Path to official Telegram MTProxy binary
MTPROXY_BIN=/usr/local/bin/mtproto-proxy

# Shared args for every worker process.
# Do NOT include -p/-H/-S here; wrapper injects them per worker.
MTPROXY_BASE_ARGS="--aes-pwd /etc/mtprotor/proxy-secret"
MTPROXY_CONFIG_FILE=/etc/mtprotor/proxy-multi.conf

# Worker wrapper computes plain port as listen_port + offset.
MTPROXY_PLAIN_PORT_OFFSET=10000

# Keep worker listeners local-only (recommended).
MTPROXY_BIND_ADDR=127.0.0.1

# Per-secret tls domain is injected automatically by mtprotor.
# MTPROXY_TLS_DOMAIN is managed at runtime; do not hardcode globally.

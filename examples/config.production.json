{
  "listen_addr": ":443",
  "admin_socket": "/run/mtprotor/admin.sock",
  "state_file": "/var/lib/mtprotor/secrets.json",
  "log_level": "info",
  "handshake_timeout_ms": 5000,
  "dial_timeout_ms": 5000,
  "drop_on_disable": false,
  "worker": {
    "mode": "command",
    "command": "/usr/local/bin/mtproto-worker-wrapper.sh",
    "args": [
      "--listen",
      "{{port}}",
      "--secret",
      "{{secret}}"
    ],
    "env": {},
    "port_range_start": 29000,
    "port_range_end": 29999,
    "start_timeout_ms": 5000,
    "stop_grace_period_seconds": 10,
    "builtin_upstream_addr": ""
  }
}

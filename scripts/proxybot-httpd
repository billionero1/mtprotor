#!/usr/bin/env python3
import base64
import hmac
import ipaddress
import json
import logging
import os
import subprocess
import threading
import time
from http import HTTPStatus
from http.server import BaseHTTPRequestHandler, ThreadingHTTPServer
from typing import Dict, List, Optional, Tuple
from urllib.parse import urlparse


def getenv_str(name: str, default: str) -> str:
    v = os.environ.get(name)
    if v is None:
        return default
    return v.strip()


def getenv_int(name: str, default: int) -> int:
    v = getenv_str(name, "")
    if not v:
        return default
    try:
        return int(v)
    except ValueError:
        return default


def getenv_bool(name: str, default: bool) -> bool:
    v = getenv_str(name, "")
    if not v:
        return default
    return v.lower() in ("1", "true", "yes", "on")


def normalize_base_path(v: str) -> str:
    if not v:
        return "/bot"
    if not v.startswith("/"):
        v = "/" + v
    if len(v) > 1 and v.endswith("/"):
        v = v[:-1]
    return v


def parse_allow_from(raw: str) -> List[ipaddress._BaseNetwork]:
    raw = raw.strip()
    if not raw:
        return []
    items = [x.strip() for x in raw.split(",") if x.strip()]
    nets: List[ipaddress._BaseNetwork] = []
    for item in items:
        if "/" not in item:
            if ":" in item:
                item = f"{item}/128"
            else:
                item = f"{item}/32"
        nets.append(ipaddress.ip_network(item, strict=False))
    return nets


LISTEN = getenv_str("BOT_HTTP_LISTEN", "0.0.0.0")
PORT = getenv_int("BOT_HTTP_PORT", 9443)
BASE_PATH = normalize_base_path(getenv_str("BOT_HTTP_BASE_PATH", "/bot"))
API_USER = getenv_str("BOT_HTTP_USER", "botapi")
API_PASSWORD = getenv_str("BOT_HTTP_PASSWORD", "")
API_KEY = getenv_str("BOT_HTTP_API_KEY", "")
ALLOW_FROM_RAW = getenv_str("BOT_HTTP_ALLOW_FROM", "")
try:
    ALLOW_FROM = parse_allow_from(ALLOW_FROM_RAW)
except ValueError as exc:
    raise SystemExit(f"invalid BOT_HTTP_ALLOW_FROM: {exc}")
TRUST_XFF = getenv_bool("BOT_HTTP_TRUST_X_FORWARDED_FOR", False)
REQUIRE_API_KEY = getenv_bool("BOT_HTTP_REQUIRE_API_KEY", True)
RATE_LIMIT_RPM = max(1, getenv_int("BOT_HTTP_RATE_LIMIT_RPM", 120))
BAN_AFTER_FAILS = max(1, getenv_int("BOT_HTTP_BAN_AFTER_FAILS", 8))
BAN_WINDOW_SECONDS = max(10, getenv_int("BOT_HTTP_BAN_WINDOW_SECONDS", 300))
BAN_SECONDS = max(30, getenv_int("BOT_HTTP_BAN_SECONDS", 900))
BODY_LIMIT_BYTES = max(1024, getenv_int("BOT_HTTP_BODY_LIMIT_BYTES", 8192))

if not API_PASSWORD:
    raise SystemExit("BOT_HTTP_PASSWORD is required")
if REQUIRE_API_KEY and not API_KEY:
    raise SystemExit("BOT_HTTP_API_KEY is required when BOT_HTTP_REQUIRE_API_KEY=true")

logging.basicConfig(level=logging.INFO, format="%(asctime)s %(levelname)s %(message)s")


class RateLimiter:
    def __init__(self, rpm: int):
        self.capacity = float(rpm)
        self.refill_per_sec = float(rpm) / 60.0
        self.lock = threading.Lock()
        self.tokens: Dict[str, Tuple[float, float]] = {}

    def allow(self, key: str) -> bool:
        now = time.time()
        with self.lock:
            tok, ts = self.tokens.get(key, (self.capacity, now))
            tok = min(self.capacity, tok + (now - ts) * self.refill_per_sec)
            if tok < 1.0:
                self.tokens[key] = (tok, now)
                return False
            tok -= 1.0
            self.tokens[key] = (tok, now)
            return True


class BanTracker:
    def __init__(self, max_fails: int, window_sec: int, ban_sec: int):
        self.max_fails = max_fails
        self.window_sec = window_sec
        self.ban_sec = ban_sec
        self.lock = threading.Lock()
        self.failures: Dict[str, List[float]] = {}
        self.blocked_until: Dict[str, float] = {}

    def is_blocked(self, ip: str) -> bool:
        now = time.time()
        with self.lock:
            until = self.blocked_until.get(ip, 0.0)
            if until <= now:
                self.blocked_until.pop(ip, None)
                return False
            return True

    def register_failure(self, ip: str) -> None:
        now = time.time()
        with self.lock:
            arr = self.failures.get(ip, [])
            arr = [t for t in arr if now - t <= self.window_sec]
            arr.append(now)
            self.failures[ip] = arr
            if len(arr) >= self.max_fails:
                self.blocked_until[ip] = now + self.ban_sec
                self.failures[ip] = []


rate_limiter = RateLimiter(RATE_LIMIT_RPM)
ban_tracker = BanTracker(BAN_AFTER_FAILS, BAN_WINDOW_SECONDS, BAN_SECONDS)


def ip_allowed(ip_str: str) -> bool:
    if not ALLOW_FROM:
        return True
    try:
        ip_obj = ipaddress.ip_address(ip_str)
    except ValueError:
        return False
    for net in ALLOW_FROM:
        if ip_obj in net:
            return True
    return False


def parse_basic_auth(header: str) -> Optional[Tuple[str, str]]:
    if not header or not header.startswith("Basic "):
        return None
    b64 = header[6:].strip()
    try:
        raw = base64.b64decode(b64).decode("utf-8", errors="strict")
    except Exception:
        return None
    if ":" not in raw:
        return None
    user, password = raw.split(":", 1)
    return user, password


def run_proxyctl(args: List[str]) -> Tuple[int, str]:
    cmd = ["/usr/local/bin/proxyctl"] + args
    env = os.environ.copy()
    env["NO_COLOR"] = "1"
    proc = subprocess.run(
        cmd,
        capture_output=True,
        text=True,
        timeout=15,
        env=env,
        check=False,
    )
    out = (proc.stdout or "").strip()
    err = (proc.stderr or "").strip()
    if out:
        return proc.returncode, out
    if err:
        return proc.returncode, json.dumps({"ok": False, "error": err})
    return proc.returncode, json.dumps({"ok": proc.returncode == 0})


class Handler(BaseHTTPRequestHandler):
    server_version = "BulldogBotHTTP/1.0"

    def log_message(self, fmt: str, *args):
        logging.info("%s - %s", self.client_address[0], fmt % args)

    def _client_ip(self) -> str:
        ip = self.client_address[0]
        if TRUST_XFF:
            xff = self.headers.get("X-Forwarded-For", "").strip()
            if xff:
                ip = xff.split(",")[0].strip()
        return ip

    def _json(self, code: int, obj: dict) -> None:
        body = json.dumps(obj, separators=(",", ":")).encode("utf-8")
        self.send_response(code)
        self.send_header("Content-Type", "application/json")
        self.send_header("Content-Length", str(len(body)))
        self.send_header("Cache-Control", "no-store")
        self.end_headers()
        self.wfile.write(body)

    def _authenticate(self, ip: str) -> bool:
        if ban_tracker.is_blocked(ip):
            self._json(HTTPStatus.TOO_MANY_REQUESTS, {"ok": False, "error": "ip temporarily blocked"})
            return False

        auth = parse_basic_auth(self.headers.get("Authorization", ""))
        if not auth:
            ban_tracker.register_failure(ip)
            self.send_response(HTTPStatus.UNAUTHORIZED)
            self.send_header("WWW-Authenticate", 'Basic realm="bulldog-bot"')
            self.send_header("Content-Type", "application/json")
            self.end_headers()
            self.wfile.write(b'{"ok":false,"error":"missing basic auth"}')
            return False

        user, password = auth
        if not (hmac.compare_digest(user, API_USER) and hmac.compare_digest(password, API_PASSWORD)):
            ban_tracker.register_failure(ip)
            self._json(HTTPStatus.UNAUTHORIZED, {"ok": False, "error": "invalid credentials"})
            return False

        if REQUIRE_API_KEY:
            api_key = self.headers.get("X-API-Key", "")
            if not hmac.compare_digest(api_key, API_KEY):
                ban_tracker.register_failure(ip)
                self._json(HTTPStatus.UNAUTHORIZED, {"ok": False, "error": "invalid api key"})
                return False

        return True

    def _check_guardrails(self) -> Optional[str]:
        ip = self._client_ip()

        if not ip_allowed(ip):
            self._json(HTTPStatus.FORBIDDEN, {"ok": False, "error": "source ip not allowed"})
            return None

        if not rate_limiter.allow(ip):
            self._json(HTTPStatus.TOO_MANY_REQUESTS, {"ok": False, "error": "rate limit exceeded"})
            return None

        if not self._authenticate(ip):
            return None

        return ip

    def _route(self) -> Tuple[str, str]:
        path = urlparse(self.path).path
        if path == BASE_PATH:
            return "/", path
        if path.startswith(BASE_PATH + "/"):
            sub = path[len(BASE_PATH):]
            return sub, path
        return "", path

    def _read_json(self) -> dict:
        raw_len = self.headers.get("Content-Length", "")
        if not raw_len.isdigit():
            return {}
        size = int(raw_len)
        if size < 0 or size > BODY_LIMIT_BYTES:
            raise ValueError("payload too large")
        if size == 0:
            return {}
        data = self.rfile.read(size)
        if not data:
            return {}
        try:
            obj = json.loads(data.decode("utf-8"))
        except Exception as exc:
            raise ValueError(f"invalid json: {exc}")
        if not isinstance(obj, dict):
            raise ValueError("json body must be object")
        return obj

    def do_GET(self):
        ip = self._check_guardrails()
        if not ip:
            return

        sub, full_path = self._route()
        if sub == "/health":
            rc, out = run_proxyctl(["bot", "health"])
        elif sub == "/secrets":
            rc, out = run_proxyctl(["secret", "list"])
        else:
            self._json(HTTPStatus.NOT_FOUND, {"ok": False, "error": "not found"})
            return

        try:
            payload = json.loads(out)
            if not isinstance(payload, dict):
                raise ValueError()
        except Exception:
            payload = {"ok": rc == 0, "raw": out}

        code = HTTPStatus.OK if rc == 0 else HTTPStatus.BAD_REQUEST
        logging.info("ip=%s method=GET path=%s rc=%s", ip, full_path, rc)
        self._json(code, payload)

    def do_POST(self):
        ip = self._check_guardrails()
        if not ip:
            return

        sub, full_path = self._route()
        if sub not in ("/issue", "/enable", "/disable", "/revoke"):
            self._json(HTTPStatus.NOT_FOUND, {"ok": False, "error": "not found"})
            return

        try:
            body = self._read_json()
        except ValueError as exc:
            self._json(HTTPStatus.BAD_REQUEST, {"ok": False, "error": str(exc)})
            return

        if sub == "/issue":
            label = str(body.get("label", "")).strip()
            if not label:
                self._json(HTTPStatus.BAD_REQUEST, {"ok": False, "error": "label is required"})
                return
            args = ["bot", "issue", label]
            if "days" in body:
                days = body.get("days")
                if not isinstance(days, int) or days < 1 or days > 3650:
                    self._json(HTTPStatus.BAD_REQUEST, {"ok": False, "error": "days must be integer 1..3650"})
                    return
                args += ["--days", str(days)]
        else:
            secret = str(body.get("secret", "")).strip().lower()
            if len(secret) != 32 or any(c not in "0123456789abcdef" for c in secret):
                self._json(HTTPStatus.BAD_REQUEST, {"ok": False, "error": "secret must be hex32"})
                return
            cmd = sub[1:]
            args = ["bot", cmd, secret]

        rc, out = run_proxyctl(args)
        try:
            payload = json.loads(out)
            if not isinstance(payload, dict):
                raise ValueError()
        except Exception:
            payload = {"ok": rc == 0, "raw": out}

        code = HTTPStatus.OK if rc == 0 else HTTPStatus.BAD_REQUEST
        logging.info("ip=%s method=POST path=%s rc=%s", ip, full_path, rc)
        self._json(code, payload)


def main() -> None:
    bind = (LISTEN, PORT)
    logging.info(
        "starting bot http bridge on %s:%d base_path=%s allow_from=%s rate_limit_rpm=%d",
        LISTEN,
        PORT,
        BASE_PATH,
        ALLOW_FROM_RAW or "any",
        RATE_LIMIT_RPM,
    )
    server = ThreadingHTTPServer(bind, Handler)
    server.daemon_threads = True
    try:
        server.serve_forever()
    except KeyboardInterrupt:
        pass
    finally:
        server.server_close()


if __name__ == "__main__":
    main()

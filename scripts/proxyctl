#!/usr/bin/env bash
set -euo pipefail

ENV_FILE="${MTPROXY_ENV_FILE:-/etc/default/mtproxy-fork}"
SERVICE_NAME="${MTPROXY_SERVICE:-}"
BRAND_NAME="${MTPROXY_BRAND_NAME:-Bulldog Proxy}"
BRAND_CONSOLE="${MTPROXY_BRAND_CONSOLE:-Bulldog Control Console}"
BRAND_RUNTIME_ID="${MTPROXY_RUNTIME_ID:-}"
DEFAULT_ENV_FILE="/etc/default/mtproxy-fork"
DEFAULT_SERVICE_NAME="mtproxy-fork"
DEFAULT_DATA_DIR="/var/lib/mtproxy-fork"
INBOUNDS_DIR="${MTPROXY_INBOUNDS_DIR:-/etc/mtproxy-fork/inbounds.d}"
INBOUND_SEQ_FILE="${MTPROXY_INBOUND_SEQ_FILE:-/var/lib/mtproxy-fork/inbound-id.seq}"
CURRENT_INBOUND="${MTPROXY_CURRENT_INBOUND:-}"
INBOUND_SELECTED="${MTPROXY_INBOUND_SELECTED:-0}"
SELF_BIN="${MTPROXY_SELF_BIN:-/usr/local/bin/proxyctl}"

if [[ ! -x "$SELF_BIN" ]]; then
  SELF_BIN="$0"
fi

inbound_name_valid() {
  local name="${1:-}"
  [[ "$name" =~ ^[1-9][0-9]*$ ]]
}

inbound_name_from_env_file() {
  local file="${1:-$DEFAULT_ENV_FILE}"
  if [[ "$file" == "$DEFAULT_ENV_FILE" || "$file" == "$INBOUNDS_DIR/1.env" ]]; then
    echo "1"
    return 0
  fi
  if [[ "$file" == "$INBOUNDS_DIR/"*.env ]]; then
    local n
    n="$(basename "$file" .env)"
    if inbound_name_valid "$n"; then
      echo "$n"
      return 0
    fi
  fi
  echo "custom"
}

inbound_env_file() {
  local name="${1:-1}"
  if [[ "$name" == "1" ]]; then
    if [[ -r "$INBOUNDS_DIR/1.env" ]]; then
      echo "$INBOUNDS_DIR/1.env"
      return 0
    fi
    echo "$DEFAULT_ENV_FILE"
  else
    echo "$INBOUNDS_DIR/$name.env"
  fi
}

inbound_service_name() {
  local name="${1:-1}"
  if [[ "$name" == "1" ]]; then
    echo "$DEFAULT_SERVICE_NAME"
  else
    echo "mtproxy-fork@$name"
  fi
}

inbound_data_dir() {
  local name="${1:-1}"
  if [[ "$name" == "1" ]]; then
    echo "$DEFAULT_DATA_DIR"
  else
    echo "$DEFAULT_DATA_DIR/$name"
  fi
}

inbound_socket_path() {
  local name="${1:-1}"
  echo "$(inbound_data_dir "$name")/admin.sock"
}

inbound_state_file() {
  local name="${1:-1}"
  echo "$(inbound_data_dir "$name")/secrets.tsv"
}

inbound_runtime_id() {
  local name="${1:-1}"
  echo "bulldog-$name"
}

if [[ -z "$CURRENT_INBOUND" ]]; then
  CURRENT_INBOUND="$(inbound_name_from_env_file "$ENV_FILE")"
fi
if [[ -z "$SERVICE_NAME" ]]; then
  SERVICE_NAME="$(inbound_service_name "$CURRENT_INBOUND")"
fi
if [[ -z "$BRAND_RUNTIME_ID" ]]; then
  BRAND_RUNTIME_ID="$(inbound_runtime_id "$CURRENT_INBOUND")"
fi

load_env() {
  local default_socket default_state
  default_socket="$(inbound_socket_path "$CURRENT_INBOUND")"
  default_state="$(inbound_state_file "$CURRENT_INBOUND")"
  if [[ -r "$ENV_FILE" ]]; then
    # shellcheck disable=SC1090
    source "$ENV_FILE"
  fi
  : "${CLIENT_PORT:=443}"
  : "${STATS_PORT:=8888}"
  : "${PUBLIC_HOST:=}"
  : "${BOOTSTRAP_SECRET:=}"
  : "${ADMIN_SOCKET:=$default_socket}"
  : "${STATE_FILE:=$default_state}"
  : "${ADMIN_TOKEN:=}"
  : "${ADMIN_TOKEN_FILE:=/etc/mtproxy-fork/admin.token}"
  : "${TLS_DOMAIN:=}"
  : "${SOURCE_DIR:=/opt/mtproxy-fork-src}"
  : "${SOURCE_REF:=main}"
  if [[ -z "${SECRET_PREFIX+x}" ]]; then
    SECRET_PREFIX="dd"
  elif [[ -z "$SECRET_PREFIX" ]]; then
    # Backward compatibility: old configs used empty for plain.
    SECRET_PREFIX="plain"
  fi
}

load_env

SOCK="${MTPROXY_SOCKET:-$ADMIN_SOCKET}"
TOKEN="${MTPROXY_TOKEN:-$ADMIN_TOKEN}"
BOT_MODE=0
BOT_SETUP_BIN="${MTPROXY_BOT_SETUP_BIN:-/usr/local/bin/mtproxybot-setup}"
BOT_CRED_FILE="${MTPROXY_BOT_CRED_FILE:-/etc/mtproxy-fork/bot-access.env}"
BOT_HTTP_SETUP_BIN="${MTPROXY_BOT_HTTP_SETUP_BIN:-/usr/local/bin/mtproxybot-http-setup}"
BOT_HTTP_CRED_FILE="${MTPROXY_BOT_HTTP_CRED_FILE:-/etc/mtproxy-fork/bot-http.env}"
BOT_HTTP_SERVICE="${MTPROXY_BOT_HTTP_SERVICE:-mtproxy-fork-bot-api}"
LOG_TAG="${MTPROXY_LOG_TAG:-dogctl}"

if [[ -t 1 && -z "${NO_COLOR:-}" ]]; then
  C_RESET=$'\033[0m'
  C_BOLD=$'\033[1m'
  C_RED=$'\033[31m'
  C_GREEN=$'\033[32m'
  C_YELLOW=$'\033[33m'
  C_CYAN=$'\033[36m'
else
  C_RESET=""
  C_BOLD=""
  C_RED=""
  C_GREEN=""
  C_YELLOW=""
  C_CYAN=""
fi

paint() {
  local color="$1"
  local text="$2"
  printf '%s%s%s' "$color" "$text" "$C_RESET"
}

paint_state() {
  local active="$1"
  local substate="$2"
  local s="${active}/${substate}"
  if [[ "$active" == "active" && "$substate" == "running" ]]; then
    paint "$C_GREEN" "$s"
  else
    paint "$C_RED" "$s"
  fi
}

paint_bool() {
  local v="$1"
  if [[ "$v" == "yes" || "$v" == "true" || "$v" == "active" ]]; then
    paint "$C_GREEN" "$v"
  else
    paint "$C_RED" "$v"
  fi
}

usage() {
  cat <<USAGE
Usage:
  proxyctl status
  proxyctl stats
  proxyctl health
  proxyctl link [--secret <hex32>] [--host <host>] [--port <port>] [--plain|--dd|--ee] [--domain <host>]

  proxyctl runtime status [--full|--json]
  proxyctl runtime start|stop|restart|logs|logs-live|update
  proxyctl service status [--full|--json]
  proxyctl service start|stop|restart|logs|logs-live|update
  proxyctl config show
  proxyctl config set client-port <1..65535>
  proxyctl config set stats-port <1..65535>
  proxyctl config set public-host <host_or_ip>
  proxyctl config set bootstrap-secret <hex32>
  proxyctl config set admin-token <token>
  proxyctl config set secret-prefix <plain|dd|ee>
  proxyctl config set stealth-mode <plain|dd|ee>
  proxyctl config set stealth-preset <standard|max-camouflage|compatibility>
  proxyctl config set tls-domain <domain|off>
  proxyctl config set domain-camouflage <domain|off>

  proxyctl inbound list [--table]
  proxyctl inbound console [<id>]
  proxyctl inbound create --port <1..65535> [--stats-port <1..65535>] [--public-host <host_or_ip>] [--mode <plain|dd|ee>] [--tls-domain <domain|off>] [--bootstrap-secret <hex32>]
  proxyctl inbound set <id> <client-port|stats-port|public-host|bootstrap-secret|stealth-mode|tls-domain> <value>
  proxyctl inbound remove <id> [--yes]

  proxyctl secret list [--table]
  proxyctl secret stats [<secret_hex>]
  proxyctl secret add <secret> [--label <label>] [--expires <unix_ts>] [--disabled]
  proxyctl secret issue <label> [--days <n> | --expires <unix_ts>] [--prefix dd|plain|ee]
  proxyctl secret update <secret> [--label <label>] [--expires <unix_ts>] [--enable|--disable]
  proxyctl secret renew <secret> [--days <n> | --expires <unix_ts>]
  proxyctl secret remove <secret>
  proxyctl secret enable <secret>
  proxyctl secret disable <secret>
  proxyctl secret expire-disable

  proxyctl bot health
  proxyctl bot issue <label> [--days <n>]
  proxyctl bot renew <secret> [--days <n> | --expires <unix_ts>]
  proxyctl bot disable <secret>
  proxyctl bot enable <secret>
  proxyctl bot revoke <secret>
  proxyctl bot api show
  proxyctl bot api rotate-password [--user <name>] [--allow-from <ip_or_cidr>|--allow-any]
  proxyctl bot api rotate-key [--user <name>] [--allow-from <ip_or_cidr>|--allow-any]
  proxyctl bot api set --user <name> [--password <pass>] [--api-key <hex64>] [--base-path </path>] [--listen <addr>] [--port <1..65535>] [--allow-from <ip_or_cidr>|--allow-any]
  proxyctl bot api status|restart
  proxyctl bot setup-password [--user <name>] [--password <pass>] [--allow-from <ip_or_cidr>]
  proxyctl bot ssh show
  proxyctl bot ssh rotate-password [--user <name>] [--allow-from <ip_or_cidr>|--allow-any]
  proxyctl bot ssh set --user <name> [--password <pass>] [--allow-from <ip_or_cidr>|--allow-any]
  proxyctl bot ssh allow-from --user <name> [--allow-from <ip_or_cidr>|--allow-any]

  proxyctl menu
  proxyctl console

Env overrides:
  MTPROXY_ENV_FILE=/etc/default/mtproxy-fork
  MTPROXY_SERVICE=mtproxy-fork
  MTPROXY_SOCKET=/var/lib/mtproxy-fork/admin.sock
  MTPROXY_TOKEN=<admin token>

Brand wrappers:
  dogctl ...   (wrapper for proxyctl ...)
  dogmenu      (wrapper for proxyctl console)
USAGE
}

warn() {
  audit_log warn "$*"
  echo "$(paint "$C_YELLOW" "[WARN]") $*" >&2
}

die() {
  audit_log error "$*"
  if (( BOT_MODE )); then
    printf '{"ok":false,"error":"%s"}\n' "$(json_escape "$*")"
  else
    echo "$(paint "$C_RED" "[ERROR]") $*" >&2
  fi
  exit 1
}

audit_log() {
  local level="$1"
  shift || true
  local msg="$*"
  if command -v logger >/dev/null 2>&1; then
    logger -t "$LOG_TAG" "level=${level} ${msg}"
  fi
}

require_root() {
  if [[ "${EUID:-$(id -u)}" -ne 0 ]]; then
    die "This action requires root"
  fi
}

require_port() {
  local p="$1"
  [[ "$p" =~ ^[0-9]+$ ]] || return 1
  (( p >= 1 && p <= 65535 )) || return 1
  return 0
}

require_hex32() {
  [[ "$1" =~ ^[0-9a-fA-F]{32}$ ]]
}

rand_hex16() {
  if command -v openssl >/dev/null 2>&1; then
    openssl rand -hex 16
    return
  fi
  od -An -N16 -tx1 /dev/urandom | tr -d ' \n'
}

rand_inbound_uid() {
  rand_hex16 | tr '[:upper:]' '[:lower:]'
}

next_inbound_id() {
  local seq_file="$INBOUND_SEQ_FILE"
  local seq_dir seq cur next
  seq_dir="$(dirname "$seq_file")"
  install -d -m 0750 -o mtproxy -g mtproxy "$seq_dir"

  if [[ -r "$seq_file" ]]; then
    seq="$(tr -dc '0-9' < "$seq_file")"
  else
    seq=""
  fi

  if [[ -z "$seq" ]]; then
    cur=1
    while IFS= read -r existing; do
      [[ "$existing" =~ ^[0-9]+$ ]] || continue
      (( existing > cur )) && cur="$existing"
    done < <(list_inbound_names)
  else
    cur="$seq"
    (( cur < 1 )) && cur=1
  fi

  next=$(( cur + 1 ))
  while inbound_exists "$next"; do
    next=$(( next + 1 ))
  done

  printf '%s\n' "$next" > "$seq_file"
  chown root:mtproxy "$seq_file" 2>/dev/null || true
  chmod 0640 "$seq_file" 2>/dev/null || true
  echo "$next"
}

rand_bootstrap_secret() {
  local s
  while true; do
    s="$(rand_hex16)"
    case "${s:0:2}" in
      dd|ee) continue ;;
      *) echo "$s"; return 0 ;;
    esac
  done
}

detect_public_host() {
  local ip
  ip="$(curl -4 -fsSL --max-time 4 https://api.ipify.org 2>/dev/null || true)"
  if [[ -n "$ip" ]]; then
    echo "$ip"
    return
  fi
  hostname -I 2>/dev/null | awk '{print $1}'
}

ensure_socket() {
  [[ -S "$SOCK" ]] || die "Admin socket not found: $SOCK"
}

json_escape() {
  printf '%s' "$1" | sed 's/\\/\\\\/g; s/"/\\"/g'
}

inbound_env_value() {
  local file="$1"
  local key="$2"
  local def="${3:-}"
  local out=""
  if [[ -r "$file" ]]; then
    out="$(awk -F= -v k="$key" '$1==k {sub(/^[^=]*=/, ""); print; exit}' "$file")"
  fi
  if [[ -n "$out" ]]; then
    echo "$out"
  else
    echo "$def"
  fi
}

inbound_uid_value() {
  local envf="$1"
  local uid=""
  uid="$(inbound_env_value "$envf" INBOUND_UID "")"
  uid="${uid,,}"
  if [[ "$uid" =~ ^[0-9a-f]{32}$ ]]; then
    echo "$uid"
    return 0
  fi

  # Backfill UID for legacy inbound env files (best effort, root only).
  if [[ "${EUID:-$(id -u)}" -eq 0 && -r "$envf" && -w "$envf" ]]; then
    uid="$(rand_inbound_uid)"
    printf '\nINBOUND_UID=%s\n' "$uid" >> "$envf"
    chown root:mtproxy "$envf" 2>/dev/null || true
    chmod 0640 "$envf" 2>/dev/null || true
    echo "$uid"
    return 0
  fi

  echo "-"
}

list_inbound_names() {
  local -a extra=()
  if [[ -r "$DEFAULT_ENV_FILE" || -r "$INBOUNDS_DIR/1.env" ]]; then
    echo "1"
  fi
  if [[ -d "$INBOUNDS_DIR" ]]; then
    local f n
    for f in "$INBOUNDS_DIR"/*.env; do
      [[ -e "$f" ]] || continue
      n="$(basename "$f" .env)"
      inbound_name_valid "$n" || continue
      [[ "$n" == "1" ]] && continue
      extra+=("$n")
    done
  fi
  if (( ${#extra[@]} > 0 )); then
    printf '%s\n' "${extra[@]}" | sort -n
  fi
}

inbound_count() {
  local n=0
  while IFS= read -r _; do
    (( n += 1 ))
  done < <(list_inbound_names)
  echo "$n"
}

inbound_exists() {
  local name="${1:-}"
  if [[ "$name" == "1" ]]; then
    [[ -r "$DEFAULT_ENV_FILE" || -r "$INBOUNDS_DIR/1.env" ]]
    return $?
  fi
  [[ -r "$(inbound_env_file "$name")" ]]
}

inbound_timer_name() {
  local name="${1:-1}"
  if [[ "$name" == "1" ]]; then
    echo "mtproxy-fork-expire-sync.timer"
  else
    echo "mtproxy-fork-expire-sync@$name.timer"
  fi
}

inbound_sync_service_name() {
  local name="${1:-1}"
  if [[ "$name" == "1" ]]; then
    echo "mtproxy-fork-expire-sync.service"
  else
    echo "mtproxy-fork-expire-sync@$name.service"
  fi
}

run_for_inbound() {
  local name="$1"
  shift
  local envf svc sock rid
  envf="$(inbound_env_file "$name")"
  svc="$(inbound_service_name "$name")"
  sock="$(inbound_socket_path "$name")"
  rid="$(inbound_runtime_id "$name")"
  env \
    MTPROXY_ENV_FILE="$envf" \
    MTPROXY_SERVICE="$svc" \
    MTPROXY_SOCKET="$sock" \
    MTPROXY_CURRENT_INBOUND="$name" \
    MTPROXY_INBOUND_SELECTED=1 \
    MTPROXY_RUNTIME_ID="$rid" \
    "$SELF_BIN" "$@"
}

exec_for_inbound() {
  local name="$1"
  shift
  local envf svc sock rid
  envf="$(inbound_env_file "$name")"
  svc="$(inbound_service_name "$name")"
  sock="$(inbound_socket_path "$name")"
  rid="$(inbound_runtime_id "$name")"
  exec env \
    MTPROXY_ENV_FILE="$envf" \
    MTPROXY_SERVICE="$svc" \
    MTPROXY_SOCKET="$sock" \
    MTPROXY_CURRENT_INBOUND="$name" \
    MTPROXY_INBOUND_SELECTED=1 \
    MTPROXY_RUNTIME_ID="$rid" \
    "$SELF_BIN" "$@"
}

port_used_by_other_inbound() {
  local port="$1"
  local exclude="${2:-}"
  local name envf p
  while IFS= read -r name; do
    [[ -n "$name" ]] || continue
    [[ "$name" == "$exclude" ]] && continue
    envf="$(inbound_env_file "$name")"
    p="$(inbound_env_value "$envf" CLIENT_PORT "")"
    if [[ -n "$p" && "$p" == "$port" ]]; then
      echo "$name"
      return 0
    fi
  done < <(list_inbound_names)
  return 1
}

request() {
  local method="$1"
  local path="$2"
  local data="${3:-}"
  local -a cmd
  cmd=(curl --silent --show-error --unix-socket "$SOCK" -X "$method")
  if [[ -n "$TOKEN" ]]; then
    cmd+=(-H "X-Admin-Token: $TOKEN")
  fi
  if [[ -n "$data" ]]; then
    cmd+=(-H "Content-Type: application/json" --data "$data")
  fi
  cmd+=("http://localhost$path")
  "${cmd[@]}"
}

api() {
  ensure_socket
  request "$@"
  echo
}

json_is_ok() {
  [[ "${1:-}" == *'"ok":true'* ]]
}

api_call_with_log() {
  local method="$1"
  local path="$2"
  local data="${3:-}"
  local ok_msg="${4:-}"
  local fail_msg="${5:-}"
  local resp
  ensure_socket
  resp="$(request "$method" "$path" "$data")"
  echo "$resp"
  if json_is_ok "$resp"; then
    [[ -n "$ok_msg" ]] && audit_log info "$ok_msg"
  else
    [[ -n "$fail_msg" ]] && audit_log warn "$fail_msg response=$(echo "$resp" | tr -d '\n')"
  fi
}

iso_utc_from_unix() {
  local ts="${1:-0}"
  if [[ ! "$ts" =~ ^[0-9]+$ ]] || (( ts <= 0 )); then
    echo "-"
    return 0
  fi
  date -u -d "@$ts" '+%Y-%m-%dT%H:%M:%SZ' 2>/dev/null || echo "$ts"
}

secrets_json_rows() {
  local json="${1:-}"
  echo "$json" \
    | tr -d '\n' \
    | sed -e 's/^.*"secrets":[[]//' -e 's/[]][[:space:]]*}.*$//' -e 's/},{/}\n{/g'
}

secret_row_field() {
  local row="$1"
  local key="$2"
  case "$key" in
    secret)
      echo "$row" | sed -n 's/.*"secret":"\([^"]*\)".*/\1/p'
      ;;
    enabled)
      echo "$row" | sed -n 's/.*"enabled":\([a-z]*\).*/\1/p'
      ;;
    active)
      echo "$row" | sed -n 's/.*"active":\([a-z]*\).*/\1/p'
      ;;
    expires)
      echo "$row" | sed -n 's/.*"expires":\([0-9][0-9]*\).*/\1/p'
      ;;
    label)
      echo "$row" | sed -n 's/.*"label":"\([^"]*\)".*/\1/p'
      ;;
    bytes_in)
      echo "$row" | sed -n 's/.*"bytes_in":\([0-9][0-9]*\).*/\1/p'
      ;;
    bytes_out)
      echo "$row" | sed -n 's/.*"bytes_out":\([0-9][0-9]*\).*/\1/p'
      ;;
    bytes_total)
      echo "$row" | sed -n 's/.*"bytes_total":\([0-9][0-9]*\).*/\1/p'
      ;;
    connections)
      echo "$row" | sed -n 's/.*"connections":\([0-9][0-9]*\).*/\1/p'
      ;;
    last_seen)
      echo "$row" | sed -n 's/.*"last_seen":\([0-9][0-9]*\).*/\1/p'
      ;;
    last_ip)
      echo "$row" | sed -n 's/.*"last_ip":"\([^"]*\)".*/\1/p'
      ;;
    *)
      echo ""
      ;;
  esac
}

stats_json_field() {
  local json="${1:-}"
  local key="${2:-}"
  case "$key" in
    secrets_total)
      echo "$json" | sed -n 's/.*"secrets":{"total":\([0-9][0-9]*\).*/\1/p'
      ;;
    secrets_active)
      echo "$json" | sed -n 's/.*"secrets":{"total":[0-9][0-9]*,"active":\([0-9][0-9]*\).*/\1/p'
      ;;
    bytes_in)
      echo "$json" | sed -n 's/.*"totals":{"bytes_in":\([0-9][0-9]*\).*/\1/p'
      ;;
    bytes_out)
      echo "$json" | sed -n 's/.*"totals":{"bytes_in":[0-9][0-9]*,"bytes_out":\([0-9][0-9]*\).*/\1/p'
      ;;
    bytes_total)
      echo "$json" | sed -n 's/.*"totals":{"bytes_in":[0-9][0-9]*,"bytes_out":[0-9][0-9]*,"bytes_total":\([0-9][0-9]*\).*/\1/p'
      ;;
    connections)
      echo "$json" | sed -n 's/.*"totals":{"bytes_in":[0-9][0-9]*,"bytes_out":[0-9][0-9]*,"bytes_total":[0-9][0-9]*,"connections":\([0-9][0-9]*\).*/\1/p'
      ;;
    *)
      echo ""
      ;;
  esac
}

load_bot_credentials() {
  local host user pass allow
  host=""
  user=""
  pass=""
  allow=""
  if [[ -r "$BOT_CRED_FILE" ]]; then
    # shellcheck disable=SC1090
    source "$BOT_CRED_FILE"
    host="${BOT_SSH_HOST:-}"
    user="${BOT_SSH_USER:-}"
    pass="${BOT_SSH_PASSWORD:-}"
    allow="${BOT_SSH_ALLOW_FROM:-}"
  fi
  printf '%s|%s|%s|%s\n' "$host" "$user" "$pass" "$allow"
}

load_bot_http_credentials() {
  local host user pass allow api_key base_path port listen
  host="${PUBLIC_HOST:-$(detect_public_host)}"
  user=""
  pass=""
  allow=""
  api_key=""
  base_path=""
  port=""
  listen=""
  if [[ -r "$BOT_HTTP_CRED_FILE" ]]; then
    # shellcheck disable=SC1090
    source "$BOT_HTTP_CRED_FILE"
    user="${BOT_HTTP_USER:-}"
    pass="${BOT_HTTP_PASSWORD:-}"
    allow="${BOT_HTTP_ALLOW_FROM:-}"
    api_key="${BOT_HTTP_API_KEY:-}"
    base_path="${BOT_HTTP_BASE_PATH:-}"
    port="${BOT_HTTP_PORT:-}"
    listen="${BOT_HTTP_LISTEN:-}"
  fi
  printf '%s|%s|%s|%s|%s|%s|%s|%s\n' "$host" "$user" "$pass" "$allow" "$api_key" "$base_path" "$port" "$listen"
}

bot_setup_exec() {
  require_root
  if [[ ! -x "$BOT_SETUP_BIN" ]]; then
    die "bot setup tool not found: $BOT_SETUP_BIN"
  fi
  "$BOT_SETUP_BIN" "$@"
}

bot_http_setup_exec() {
  require_root
  if [[ ! -x "$BOT_HTTP_SETUP_BIN" ]]; then
    die "bot http setup tool not found: $BOT_HTTP_SETUP_BIN"
  fi
  "$BOT_HTTP_SETUP_BIN" "$@"
}

service_cmd() {
  local action="$1"
  local mode="${2:-}"
  case "$action" in
    status)
      case "$mode" in
        --full)
          systemctl --no-pager --full status "$SERVICE_NAME.service"
          ;;
        --json)
          print_service_summary_json
          ;;
        "")
          print_service_summary
          ;;
        *)
          die "Unknown option for service status: $mode"
          ;;
      esac
      ;;
    start|stop|restart)
      require_root
      systemctl "$action" "$SERVICE_NAME.service"
      ;;
    update)
      runtime_update
      ;;
    logs)
      local pat
      pat="(${SERVICE_NAME}|mtproto-proxy-fork|mtproxy-fork-expire-sync|mtproxy-fork-bot-api|${LOG_TAG}|proxyctl)"
      journalctl --no-pager -n 800 -o short-iso --no-hostname | grep -E "$pat" | tail -n 120 || true
      ;;
    logs-live|logs-follow)
      local live_pat
      live_pat="(${SERVICE_NAME}|mtproto-proxy-fork|mtproxy-fork-expire-sync|mtproxy-fork-bot-api|${LOG_TAG}|proxyctl)"
      journalctl -f -o short-iso --no-hostname | grep --line-buffered -E "$live_pat"
      ;;
    *)
      die "Unknown service action: $action"
      ;;
  esac
}

runtime_update() {
  require_root
  local src="$SOURCE_DIR"
  local ref="${SOURCE_REF:-main}"
  local jobs unit_file unit_tmpl expire_service expire_timer expire_service_tmpl expire_timer_tmpl bot_http_unit
  local bin ctl dogctl dogmenu dispatch botsetup bothttpd bothttpsetup runner menu

  unit_file="/etc/systemd/system/mtproxy-fork.service"
  unit_tmpl="/etc/systemd/system/mtproxy-fork@.service"
  expire_service="/etc/systemd/system/mtproxy-fork-expire-sync.service"
  expire_timer="/etc/systemd/system/mtproxy-fork-expire-sync.timer"
  expire_service_tmpl="/etc/systemd/system/mtproxy-fork-expire-sync@.service"
  expire_timer_tmpl="/etc/systemd/system/mtproxy-fork-expire-sync@.timer"
  bot_http_unit="/etc/systemd/system/mtproxy-fork-bot-api.service"
  bin="/usr/local/bin/mtproto-proxy-fork"
  ctl="/usr/local/bin/proxyctl"
  dogctl="/usr/local/bin/dogctl"
  dogmenu="/usr/local/bin/dogmenu"
  dispatch="/usr/local/bin/proxybot-dispatch"
  botsetup="/usr/local/bin/mtproxybot-setup"
  bothttpd="/usr/local/bin/proxybot-httpd"
  bothttpsetup="/usr/local/bin/mtproxybot-http-setup"
  runner="/usr/local/bin/mtproxy-fork-run"
  menu="/usr/local/bin/mtproxymenu"

  [[ -d "$src/.git" ]] || die "source repo not found at $src (set SOURCE_DIR in $ENV_FILE)"

  echo "[update] source: $src"
  echo "[update] ref: $ref"
  git -C "$src" fetch --depth 1 origin "$ref"
  git -C "$src" checkout -q "$ref"
  git -C "$src" reset --hard "origin/$ref"

  jobs="$(nproc 2>/dev/null || echo 1)"
  [[ "$jobs" =~ ^[0-9]+$ ]] || jobs=1
  (( jobs > 0 )) || jobs=1
  echo "[update] build jobs: $jobs"
  make -C "$src" clean
  make -C "$src" -j"$jobs"

  install -m 0755 "$src/objs/bin/mtproto-proxy" "$bin"
  install -m 0755 "$src/scripts/proxyctl" "$ctl"
  install -m 0755 "$src/scripts/dogctl" "$dogctl"
  install -m 0755 "$src/scripts/dogmenu" "$dogmenu"
  install -m 0755 "$src/scripts/proxybot-dispatch" "$dispatch"
  install -m 0755 "$src/scripts/mtproxybot-setup" "$botsetup"
  if [[ -f "$src/scripts/proxybot-httpd" ]]; then
    install -m 0755 "$src/scripts/proxybot-httpd" "$bothttpd"
  fi
  if [[ -f "$src/scripts/mtproxybot-http-setup" ]]; then
    install -m 0755 "$src/scripts/mtproxybot-http-setup" "$bothttpsetup"
  fi
  if [[ -f "$src/scripts/mtproxy-fork-run" ]]; then
    install -m 0755 "$src/scripts/mtproxy-fork-run" "$runner"
  fi
  install -m 0644 "$src/systemd/mtproxy-fork.service" "$unit_file"
  if [[ -f "$src/systemd/mtproxy-fork@.service" ]]; then
    install -m 0644 "$src/systemd/mtproxy-fork@.service" "$unit_tmpl"
  fi
  install -m 0644 "$src/systemd/mtproxy-fork-expire-sync.service" "$expire_service"
  install -m 0644 "$src/systemd/mtproxy-fork-expire-sync.timer" "$expire_timer"
  if [[ -f "$src/systemd/mtproxy-fork-expire-sync@.service" ]]; then
    install -m 0644 "$src/systemd/mtproxy-fork-expire-sync@.service" "$expire_service_tmpl"
  fi
  if [[ -f "$src/systemd/mtproxy-fork-expire-sync@.timer" ]]; then
    install -m 0644 "$src/systemd/mtproxy-fork-expire-sync@.timer" "$expire_timer_tmpl"
  fi
  if [[ -f "$src/systemd/mtproxy-fork-bot-api.service" ]]; then
    install -m 0644 "$src/systemd/mtproxy-fork-bot-api.service" "$bot_http_unit"
  fi
  cat > "$menu" <<'MENU'
#!/usr/bin/env bash
exec /usr/local/bin/dogmenu "$@"
MENU
  chmod 0755 "$menu"

  systemctl daemon-reload
  systemctl enable --now mtproxy-fork-expire-sync.timer >/dev/null 2>&1 || true
  if [[ -f "$bot_http_unit" && -r "$BOT_HTTP_CRED_FILE" ]]; then
    systemctl enable --now "$BOT_HTTP_SERVICE.service" >/dev/null 2>&1 || true
    systemctl try-restart "$BOT_HTTP_SERVICE.service" >/dev/null 2>&1 || true
  fi
  systemctl restart "$SERVICE_NAME.service"
  systemctl is-active --quiet "$SERVICE_NAME.service" || die "service failed after update; check journalctl -u $SERVICE_NAME -n 120"

  local rev
  rev="$(git -C "$src" rev-parse --short HEAD 2>/dev/null || echo unknown)"
  echo "[update] done: revision=$rev"
}

update_env_key() {
  local key="$1"
  local value="$2"
  local tmp
  tmp="$(mktemp)"
  if [[ -r "$ENV_FILE" ]]; then
    awk -F= -v k="$key" -v v="$value" '
      BEGIN {found=0}
      $1 == k {print k "=" v; found=1; next}
      {print}
      END {if (!found) print k "=" v}
    ' "$ENV_FILE" > "$tmp"
  else
    printf '%s=%s\n' "$key" "$value" > "$tmp"
  fi
  install -m 0640 -o root -g mtproxy "$tmp" "$ENV_FILE" 2>/dev/null || install -m 0640 "$tmp" "$ENV_FILE"
  rm -f "$tmp"
}

write_admin_token_file() {
  local token="$1"
  local dir tmp
  dir="$(dirname "$ADMIN_TOKEN_FILE")"
  install -d -m 0750 -o root -g mtproxy "$dir" 2>/dev/null || mkdir -p "$dir"
  tmp="$(mktemp)"
  printf '%s\n' "$token" > "$tmp"
  install -m 0640 -o root -g mtproxy "$tmp" "$ADMIN_TOKEN_FILE" 2>/dev/null || install -m 0600 "$tmp" "$ADMIN_TOKEN_FILE"
  rm -f "$tmp"
}

link_secret() {
  local sec="$1"
  local pref="${2:-$SECRET_PREFIX}"
  local tls_domain="${3:-$TLS_DOMAIN}"
  local domain_hex=""
  if [[ -n "${tls_domain:-}" ]]; then
    domain_hex="$(domain_to_hex "$tls_domain")"
  fi
  case "${pref,,}" in
    plain|"") echo "$sec" ;;
    dd) echo "dd$sec" ;;
    ee) echo "ee$sec$domain_hex" ;;
    *) echo "$sec" ;;
  esac
}

stealth_mode_name() {
  local pref="${1:-$SECRET_PREFIX}"
  case "${pref,,}" in
    ""|plain) echo "plain" ;;
    dd) echo "dd" ;;
    ee) echo "ee" ;;
    *) echo "${pref,,}" ;;
  esac
}

normalize_secret_prefix() {
  local in="${1:-}"
  case "${in,,}" in
    plain|"") echo "plain" ;;
    dd) echo "dd" ;;
    ee) echo "ee" ;;
    *) return 1 ;;
  esac
}

is_valid_domain_name() {
  local d="${1,,}"
  [[ -n "$d" ]] || return 1
  [[ "$d" == *.* ]] || return 1
  [[ "$d" != .* && "$d" != *. && "$d" != *..* ]] || return 1
  [[ "$d" =~ ^[a-z0-9.-]+$ ]] || return 1
  local part
  IFS='.' read -r -a parts <<<"$d"
  for part in "${parts[@]}"; do
    [[ -n "$part" && ${#part} -le 63 ]] || return 1
    [[ "$part" =~ ^[a-z0-9]([a-z0-9-]*[a-z0-9])?$ ]] || return 1
  done
  return 0
}

normalize_tls_domain() {
  local in="${1:-}"
  case "${in,,}" in
    ""|off|none|disable|disabled|no)
      echo ""
      return 0
      ;;
  esac
  in="${in,,}"
  is_valid_domain_name "$in" || return 1
  echo "$in"
}

domain_to_hex() {
  local d="${1,,}"
  printf '%s' "$d" | od -An -tx1 -v | tr -d ' \n'
}

stealth_preset_to_mode() {
  local preset="${1:-}"
  case "${preset,,}" in
    standard|std|default|balanced)
      echo "dd"
      ;;
    max-camouflage|max-camouflage|max|camouflage|ee|tls)
      echo "ee"
      ;;
    compatibility|compat|plain)
      echo "plain"
      ;;
    *)
      return 1
      ;;
  esac
}

print_stealth_explain() {
  cat <<TXT
Stealth modes:
  plain
    - Secret in link is just 32 hex (no prefix).
    - Best for compatibility/debug cases.
    - Least camouflage.

  dd (Standard)
    - Secret in link uses dd<secret>.
    - Default balanced mode for most deployments.
    - Good compatibility with practical obfuscation.

  ee (Max camouflage)
    - Secret in link uses ee<secret>[optional suffix].
    - More TLS-like transport behavior.
    - Best when you need stronger camouflage.

Cover domain (optional, advanced):
  - Set with: proxyctl config set tls-domain <domain>
  - Example: proxyctl config set tls-domain www.google.com
  - This forces runtime TLS-domain mode and appends domain suffix to ee links.
  - Disable with: proxyctl config set tls-domain off
TXT
}

show_links() {
  local sec="$1"
  local host="${2:-$PUBLIC_HOST}"
  local port="${3:-$CLIENT_PORT}"
  local pref="${4:-$SECRET_PREFIX}"
  local tls_domain="${5:-$TLS_DOMAIN}"
  [[ -n "$host" ]] || host="$(detect_public_host)"
  [[ -n "$host" ]] || die "Cannot determine public host; set it with: proxyctl config set public-host <host>"
  local secret_out
  secret_out="$(link_secret "$sec" "$pref" "$tls_domain")"
  echo "https://t.me/proxy?server=${host}&port=${port}&secret=${secret_out}"
  echo "tg://proxy?server=${host}&port=${port}&secret=${secret_out}"
}

fmt_bytes() {
  local b="${1:-0}"
  if command -v numfmt >/dev/null 2>&1; then
    numfmt --to=iec-i --suffix=B "$b" 2>/dev/null || echo "${b}B"
  else
    echo "${b}B"
  fi
}

fmt_cpu_nsec() {
  local ns="${1:-0}"
  awk -v n="$ns" 'BEGIN { printf "%.2fs", (n/1000000000.0) }'
}

collect_service_snapshot() {
  local status_json
  local active substate pid start_ts mem cpu total active_secrets listen host
  active="$(systemctl show -p ActiveState --value "$SERVICE_NAME.service" 2>/dev/null || echo unknown)"
  substate="$(systemctl show -p SubState --value "$SERVICE_NAME.service" 2>/dev/null || echo unknown)"
  pid="$(systemctl show -p MainPID --value "$SERVICE_NAME.service" 2>/dev/null || echo 0)"
  start_ts="$(systemctl show -p ActiveEnterTimestamp --value "$SERVICE_NAME.service" 2>/dev/null || echo unknown)"
  mem="$(systemctl show -p MemoryCurrent --value "$SERVICE_NAME.service" 2>/dev/null || echo 0)"
  cpu="$(systemctl show -p CPUUsageNSec --value "$SERVICE_NAME.service" 2>/dev/null || echo 0)"
  listen="no"
  if ss -ltn | awk '{print $4}' | grep -qE "(^|:)${CLIENT_PORT}$"; then
    listen="yes"
  fi
  host="${PUBLIC_HOST:-$(detect_public_host)}"
  total=0
  active_secrets=0
  if [[ -S "$SOCK" ]]; then
    status_json="$(request GET /v1/status 2>/dev/null || true)"
    total="$(echo "$status_json" | sed -n 's/.*"total":\([0-9][0-9]*\).*/\1/p')"
    active_secrets="$(echo "$status_json" | sed -n 's/.*"active":\([0-9][0-9]*\).*/\1/p')"
    [[ -n "$total" ]] || total=0
    [[ -n "$active_secrets" ]] || active_secrets=0
  fi
  printf '%s|%s|%s|%s|%s|%s|%s|%s|%s|%s\n' \
    "$active" "$substate" "$pid" "$start_ts" "$mem" "$cpu" "$listen" "$host" "$total" "$active_secrets"
}

print_service_summary() {
  local snap active substate pid start_ts mem cpu listen host total active_secrets
  snap="$(collect_service_snapshot)"
  IFS='|' read -r active substate pid start_ts mem cpu listen host total active_secrets <<<"$snap"
  echo "Runtime      : $(paint "$C_BOLD" "$BRAND_NAME") ($(paint_state "$active" "$substate"))"
  echo "Runtime ID   : $BRAND_RUNTIME_ID"
  echo "Inbound      : $CURRENT_INBOUND"
  echo "Service      : $SERVICE_NAME"
  echo "Main PID     : $(paint "$C_CYAN" "$pid")"
  echo "Started      : $start_ts"
  echo "Memory       : $(fmt_bytes "$mem")"
  echo "CPU time     : $(fmt_cpu_nsec "$cpu")"
  echo "Client port  : $(paint "$C_CYAN" "$CLIENT_PORT") (listening: $(paint_bool "$listen"))"
  echo "Public host  : ${host:-unknown}"
  echo "Secrets      : total=$(paint "$C_CYAN" "$total") active=$(paint "$C_CYAN" "$active_secrets")"
}

print_service_summary_json() {
  local snap active substate pid start_ts mem cpu listen host total active_secrets
  snap="$(collect_service_snapshot)"
  IFS='|' read -r active substate pid start_ts mem cpu listen host total active_secrets <<<"$snap"
  printf '{\"brand\":\"%s\",\"runtime_id\":\"%s\",\"inbound\":\"%s\",\"service\":\"%s\",\"active\":\"%s\",\"substate\":\"%s\",\"pid\":%s,\"started\":\"%s\",\"memory_bytes\":%s,\"cpu_nsec\":%s,\"client_port\":%s,\"listening\":\"%s\",\"public_host\":\"%s\",\"secrets_total\":%s,\"secrets_active\":%s}\n' \
    "$(json_escape "$BRAND_NAME")" "$(json_escape "$BRAND_RUNTIME_ID")" "$(json_escape "$CURRENT_INBOUND")" "$SERVICE_NAME" "$active" "$substate" "$pid" "$(json_escape "$start_ts")" "$mem" "$cpu" "$CLIENT_PORT" "$listen" "$(json_escape "$host")" "$total" "$active_secrets"
}

cmd_status() {
  api GET /v1/status
}

cmd_stats() {
  api GET /v1/stats
}

cmd_health() {
  local active="no"
  local api_ok="no"
  local listen="no"
  if systemctl is-active --quiet "$SERVICE_NAME.service"; then
    active="yes"
  fi
  if [[ -S "$SOCK" ]]; then
    if request GET /v1/status >/dev/null 2>&1; then
      api_ok="yes"
    fi
  fi
  if ss -ltn | awk '{print $4}' | grep -qE "(^|:)${CLIENT_PORT}$"; then
    listen="yes"
  fi
  printf '{"service_active":"%s","api_ok":"%s","listener_%s":"%s"}\n' "$active" "$api_ok" "$CLIENT_PORT" "$listen"
}

cmd_link() {
  local sec="${BOOTSTRAP_SECRET,,}"
  local host="$PUBLIC_HOST"
  local port="$CLIENT_PORT"
  local pref="$SECRET_PREFIX"
  local tls_domain="$TLS_DOMAIN"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --secret)
        sec="${2:-}"; shift 2 ;;
      --host)
        host="${2:-}"; shift 2 ;;
      --port)
        port="${2:-}"; shift 2 ;;
      --plain)
        pref="plain"; shift ;;
      --dd)
        pref="dd"; shift ;;
      --ee)
        pref="ee"; shift ;;
      --domain)
        tls_domain="${2:-}"; shift 2 ;;
      *)
        die "Unknown link option: $1"
        ;;
    esac
  done
  require_hex32 "$sec" || die "secret must be 32 hex chars"
  require_port "$port" || die "port must be 1..65535"
  if [[ -n "$tls_domain" ]] && ! is_valid_domain_name "$tls_domain"; then
    die "domain must be a valid hostname"
  fi
  show_links "${sec,,}" "$host" "$port" "$pref" "${tls_domain,,}"
}

cmd_config_show() {
  cat <<CFG
INBOUND=$CURRENT_INBOUND
SERVICE_NAME=$SERVICE_NAME
ENV_FILE=$ENV_FILE
SOURCE_DIR=$SOURCE_DIR
SOURCE_REF=$SOURCE_REF
CLIENT_PORT=$CLIENT_PORT
STATS_PORT=$STATS_PORT
PUBLIC_HOST=$PUBLIC_HOST
BOOTSTRAP_SECRET=$BOOTSTRAP_SECRET
SECRET_PREFIX=$SECRET_PREFIX
STEALTH_MODE=$(stealth_mode_name)
TLS_DOMAIN=${TLS_DOMAIN:-}
DOMAIN_CAMOUFLAGE=$([[ -n "${TLS_DOMAIN:-}" ]] && echo enabled || echo disabled)
ADMIN_SOCKET=$ADMIN_SOCKET
STATE_FILE=$STATE_FILE
ADMIN_TOKEN_FILE=$ADMIN_TOKEN_FILE
ADMIN_TOKEN=${ADMIN_TOKEN:0:8}...
CFG
  echo "Default links:"
  cmd_link
}

apply_runtime_bootstrap_swap() {
  local old="$1"
  local new="$2"
  if [[ -S "$SOCK" ]]; then
    local payload
    payload="{\"secret\":\"$new\",\"label\":\"bootstrap\",\"enabled\":true,\"expires\":0}"
    request POST /v1/secrets "$payload" >/dev/null || warn "failed to add new bootstrap secret via runtime API"
    if [[ -n "$old" && "$old" != "$new" ]]; then
      request DELETE "/v1/secrets/$old" >/dev/null || warn "old bootstrap secret not removed (can remove manually)"
    fi
  fi
}

cmd_config_set() {
  require_root
  local key="${1:-}"
  local val="${2:-}"
  [[ -n "$key" && -n "$val" ]] || die "Usage: proxyctl config set <key> <value>"

  case "$key" in
    client-port)
      require_port "$val" || die "invalid port"
      update_env_key CLIENT_PORT "$val"
      CLIENT_PORT="$val"
      systemctl restart "$SERVICE_NAME.service"
      echo "client-port updated to $val"
      cmd_link
      ;;
    stats-port)
      require_port "$val" || die "invalid port"
      update_env_key STATS_PORT "$val"
      STATS_PORT="$val"
      systemctl restart "$SERVICE_NAME.service"
      echo "stats-port updated to $val"
      ;;
    public-host)
      update_env_key PUBLIC_HOST "$val"
      PUBLIC_HOST="$val"
      echo "public-host updated"
      cmd_link
      ;;
    admin-token)
      update_env_key ADMIN_TOKEN "$val"
      if ! write_admin_token_file "$val"; then
        die "failed to write admin token file: $ADMIN_TOKEN_FILE"
      fi
      ADMIN_TOKEN="$val"
      TOKEN="$val"
      systemctl restart "$SERVICE_NAME.service"
      echo "admin-token updated, token file refreshed, service restarted"
      ;;
    bootstrap-secret)
      require_hex32 "$val" || die "bootstrap-secret must be 32 hex chars"
      val="${val,,}"
      apply_runtime_bootstrap_swap "${BOOTSTRAP_SECRET,,}" "$val"
      update_env_key BOOTSTRAP_SECRET "$val"
      BOOTSTRAP_SECRET="$val"
      echo "bootstrap-secret updated"
      cmd_link
      ;;
    secret-prefix|stealth-mode)
      if ! val="$(normalize_secret_prefix "$val")"; then
        die "secret-prefix must be plain, dd or ee"
      fi
      if [[ -n "${TLS_DOMAIN:-}" && "$val" != "ee" ]]; then
        die "TLS domain camouflage is enabled for '$TLS_DOMAIN'; stealth mode must stay 'ee' until tls-domain is off"
      fi
      update_env_key SECRET_PREFIX "$val"
      SECRET_PREFIX="$val"
      echo "secret-prefix updated (mode: $(stealth_mode_name "$val"))"
      cmd_link
      ;;
    stealth-preset)
      if ! val="$(stealth_preset_to_mode "$val")"; then
        die "stealth-preset must be standard, max-camouflage or compatibility"
      fi
      if [[ -n "${TLS_DOMAIN:-}" && "$val" != "ee" ]]; then
        die "TLS domain camouflage is enabled for '$TLS_DOMAIN'; choose max-camouflage (ee) or disable tls-domain first"
      fi
      update_env_key SECRET_PREFIX "$val"
      SECRET_PREFIX="$val"
      echo "stealth-preset applied (mode: $(stealth_mode_name "$val"))"
      cmd_link
      ;;
    tls-domain|domain-camouflage)
      if ! val="$(normalize_tls_domain "$val")"; then
        die "tls-domain must be a valid domain (example: www.google.com) or off"
      fi
      update_env_key TLS_DOMAIN "$val"
      TLS_DOMAIN="$val"
      if [[ -n "$val" ]]; then
        if [[ "${SECRET_PREFIX,,}" != "ee" ]]; then
          SECRET_PREFIX="ee"
          update_env_key SECRET_PREFIX "ee"
          echo "stealth-mode auto-switched to ee for TLS domain camouflage"
        fi
        systemctl restart "$SERVICE_NAME.service"
        echo "tls-domain enabled: $val (runtime restarted)"
      else
        systemctl restart "$SERVICE_NAME.service"
        echo "tls-domain disabled (runtime restarted)"
      fi
      cmd_link
      ;;
    *)
      die "Unknown config key: $key"
      ;;
  esac
}

cmd_inbound_list_table() {
  printf '%-6s %-34s %-22s %-6s %-6s %-20s %-16s %-32s\n' \
    "ID" "UID" "SERVICE" "PORT" "MODE" "TLS_DOMAIN" "STATUS" "SOCKET"
  local name envf uid svc port mode tls socket active substate status
  while IFS= read -r name; do
    [[ -n "$name" ]] || continue
    envf="$(inbound_env_file "$name")"
    uid="$(inbound_uid_value "$envf")"
    svc="$(inbound_service_name "$name")"
    port="$(inbound_env_value "$envf" CLIENT_PORT "443")"
    mode="$(inbound_env_value "$envf" SECRET_PREFIX "dd")"
    tls="$(inbound_env_value "$envf" TLS_DOMAIN "off")"
    [[ -n "$tls" ]] || tls="off"
    socket="$(inbound_env_value "$envf" ADMIN_SOCKET "$(inbound_socket_path "$name")")"
    active="$(systemctl show -p ActiveState --value "$svc.service" 2>/dev/null || echo unknown)"
    substate="$(systemctl show -p SubState --value "$svc.service" 2>/dev/null || echo unknown)"
    status="$active/$substate"
    printf '%-6s %-34s %-22s %-6s %-6s %-20s %-16s %-32s\n' \
      "$name" "$uid" "$svc" "$port" "$mode" "$tls" "$status" "$socket"
  done < <(list_inbound_names)
}

pick_inbound_interactive() {
  local prompt="${1:-Select inbound ID: }"
  local -a names=()
  local name idx choice
  while IFS= read -r name; do
    [[ -n "$name" ]] || continue
    names+=("$name")
  done < <(list_inbound_names)
  if (( ${#names[@]} == 0 )); then
    warn "No inbounds configured"
    return 1
  fi
  if (( ${#names[@]} == 1 )); then
    echo "${names[0]}"
    return 0
  fi
  echo >&2
  echo "Available inbound IDs:" >&2
  idx=1
  for name in "${names[@]}"; do
    local envf svc port mode tls active substate host
    envf="$(inbound_env_file "$name")"
    svc="$(inbound_service_name "$name")"
    port="$(inbound_env_value "$envf" CLIENT_PORT "443")"
    mode="$(inbound_env_value "$envf" SECRET_PREFIX "dd")"
    tls="$(inbound_env_value "$envf" TLS_DOMAIN "off")"
    host="$(inbound_env_value "$envf" PUBLIC_HOST "unknown")"
    [[ -n "$tls" ]] || tls="off"
    active="$(systemctl show -p ActiveState --value "$svc.service" 2>/dev/null || echo unknown)"
    substate="$(systemctl show -p SubState --value "$svc.service" 2>/dev/null || echo unknown)"
    printf '%d) ID %s  (%s:%s, mode=%s, tls=%s, %s/%s)\n' \
      "$idx" "$name" "$host" "$port" "$mode" "$tls" "$active" "$substate" >&2
    (( idx += 1 ))
  done
  printf "%s" "$prompt" >&2
  IFS= read -r choice || true
  if [[ "$choice" =~ ^[0-9]+$ ]] && (( choice >= 1 && choice <= ${#names[@]} )); then
    echo "${names[choice-1]}"
    return 0
  fi
  warn "Invalid selection"
  return 1
}

cmd_inbound_console() {
  local id="${1:-}"
  if [[ -z "$id" ]]; then
    if [[ -t 0 ]]; then
      id="$(pick_inbound_interactive "Select inbound ID to open: ")" || return 1
    else
      die "inbound id is required in non-interactive mode"
    fi
  fi
  if ! inbound_name_valid "$id"; then
    die "invalid inbound id: $id"
  fi
  if ! inbound_exists "$id"; then
    die "inbound not found: $id"
  fi
  exec_for_inbound "$id" console
}

cmd_inbound_create() {
  require_root
  [[ $# -gt 0 ]] || die "Usage: proxyctl inbound create --port <1..65535> [--stats-port <1..65535>] [--public-host <host_or_ip>] [--mode <plain|dd|ee>] [--tls-domain <domain|off>] [--bootstrap-secret <hex32>]"

  local port=""
  local stats_port="8888"
  local host="${PUBLIC_HOST:-}"
  local mode="$SECRET_PREFIX"
  local tls_domain=""
  local bootstrap=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --port)
        port="${2:-}"; shift 2 ;;
      --stats-port)
        stats_port="${2:-}"; shift 2 ;;
      --public-host)
        host="${2:-}"; shift 2 ;;
      --mode|--stealth-mode|--prefix)
        mode="${2:-}"; shift 2 ;;
      --tls-domain|--domain-camouflage)
        tls_domain="${2:-}"; shift 2 ;;
      --bootstrap-secret)
        bootstrap="${2:-}"; shift 2 ;;
      *)
        die "Unknown inbound create option: $1"
        ;;
    esac
  done

  local id
  id="$(next_inbound_id)"

  [[ -n "$port" ]] || die "--port is required"
  require_port "$port" || die "invalid --port value"
  require_port "$stats_port" || die "invalid --stats-port value"
  if ! mode="$(normalize_secret_prefix "$mode")"; then
    die "mode must be plain, dd or ee"
  fi
  if [[ -n "$tls_domain" ]]; then
    if ! tls_domain="$(normalize_tls_domain "$tls_domain")"; then
      die "invalid tls-domain value"
    fi
    if [[ -n "$tls_domain" && "$mode" != "ee" ]]; then
      warn "TLS domain requires ee mode; switching mode to ee"
      mode="ee"
    fi
  fi
  if [[ -z "$bootstrap" ]]; then
    bootstrap="$(rand_bootstrap_secret)"
  fi
  require_hex32 "$bootstrap" || die "bootstrap-secret must be 32 hex chars"
  bootstrap="${bootstrap,,}"

  local used_by
  used_by="$(port_used_by_other_inbound "$port" "" || true)"
  if [[ -n "$used_by" ]]; then
    die "port $port is already configured by inbound ID '$used_by'"
  fi
  if ss -ltn | awk '{print $4}' | grep -qE "(^|:)${port}$"; then
    die "port $port is already listening on this host"
  fi

  local svc_tmpl="/etc/systemd/system/mtproxy-fork@.service"
  local sync_tmpl="/etc/systemd/system/mtproxy-fork-expire-sync@.service"
  local timer_tmpl="/etc/systemd/system/mtproxy-fork-expire-sync@.timer"
  [[ -r "$svc_tmpl" ]] || die "missing $svc_tmpl (run: proxyctl runtime update)"
  [[ -r "$sync_tmpl" ]] || die "missing $sync_tmpl (run: proxyctl runtime update)"
  [[ -r "$timer_tmpl" ]] || die "missing $timer_tmpl (run: proxyctl runtime update)"

  local envf data_dir socket state tmp_env now inbound_uid
  envf="$(inbound_env_file "$id")"
  data_dir="$(inbound_data_dir "$id")"
  socket="$(inbound_socket_path "$id")"
  state="$(inbound_state_file "$id")"
  inbound_uid="$(rand_inbound_uid)"

  install -d -m 0750 -o root -g mtproxy "$INBOUNDS_DIR"
  install -d -m 0750 -o mtproxy -g mtproxy "$data_dir"
  tmp_env="$(mktemp)"
  cat >"$tmp_env" <<ENV
CLIENT_PORT=$port
STATS_PORT=$stats_port
PUBLIC_HOST=$host
BOOTSTRAP_SECRET=$bootstrap
SECRET_PREFIX=$mode
TLS_DOMAIN=$tls_domain
ADMIN_SOCKET=$socket
STATE_FILE=$state
ADMIN_TOKEN_FILE=$ADMIN_TOKEN_FILE
ADMIN_TOKEN=$ADMIN_TOKEN
SOURCE_DIR=$SOURCE_DIR
SOURCE_REF=$SOURCE_REF
INBOUND_UID=$inbound_uid
ENV
  install -m 0640 -o root -g mtproxy "$tmp_env" "$envf" 2>/dev/null || install -m 0640 "$tmp_env" "$envf"
  rm -f "$tmp_env"

  now="$(date +%s)"
  {
    echo "v1"
    printf "%s\t1\t0\t%s\t%s\tbootstrap\n" "$bootstrap" "$now" "$now"
  } > "$state"
  chown mtproxy:mtproxy "$state"
  chmod 0640 "$state"

  systemctl daemon-reload
  systemctl enable --now "$(inbound_service_name "$id").service"
  systemctl enable --now "$(inbound_timer_name "$id")"
  systemctl is-active --quiet "$(inbound_service_name "$id").service" || die "failed to start inbound service: $(inbound_service_name "$id").service"

  echo "inbound created: id=$id"
  run_for_inbound "$id" link --secret "$bootstrap" --host "$host" --port "$port"
}

cmd_inbound_set() {
  local id="${1:-}"
  local key="${2:-}"
  local value="${3:-}"
  [[ -n "$id" && -n "$key" && -n "$value" ]] || die "Usage: proxyctl inbound set <id> <key> <value>"
  inbound_name_valid "$id" || die "invalid inbound id: $id"
  if ! inbound_exists "$id"; then
    die "inbound not found: $id"
  fi
  run_for_inbound "$id" config set "$key" "$value"
}

cmd_inbound_remove() {
  require_root
  local id="${1:-}"
  shift || true
  [[ -n "$id" ]] || die "Usage: proxyctl inbound remove <id> [--yes]"
  inbound_name_valid "$id" || die "invalid inbound id"
  [[ "$id" != "1" ]] || die "inbound ID 1 cannot be removed"
  if ! inbound_exists "$id"; then
    die "inbound not found: $id"
  fi

  local yes=0
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --yes) yes=1; shift ;;
      *) die "Unknown inbound remove option: $1" ;;
    esac
  done

  if (( yes == 0 )); then
    if [[ ! -t 0 ]]; then
      die "confirmation required (use --yes)"
    fi
    local answer=""
    printf "Remove inbound ID '%s' with all its state/statistics? [y/N]: " "$id"
    IFS= read -r answer || true
    case "${answer,,}" in
      y|yes) ;;
      *) echo "aborted"; return 0 ;;
    esac
  fi

  systemctl disable --now "$(inbound_timer_name "$id")" "$(inbound_sync_service_name "$id")" "$(inbound_service_name "$id").service" 2>/dev/null || true
  rm -f "$(inbound_env_file "$id")"
  rm -rf "$(inbound_data_dir "$id")"
  systemctl daemon-reload
  echo "inbound removed: id=$id"
}

cmd_inbound() {
  local sub="${1:-}"
  shift || true
  case "$sub" in
    list)
      local mode="${1:-}"
      if [[ "$mode" == "--table" ]]; then
        cmd_inbound_list_table
      else
        list_inbound_names
      fi
      ;;
    console)
      cmd_inbound_console "${1:-}"
      ;;
    create)
      cmd_inbound_create "$@"
      ;;
    set)
      cmd_inbound_set "$@"
      ;;
    remove|delete|rm)
      local name_rm="${1:-}"
      [[ -n "$name_rm" ]] || die "Usage: proxyctl inbound remove <id> [--yes]"
      shift || true
      cmd_inbound_remove "$name_rm" "$@"
      ;;
    *)
      die "Unknown inbound action: $sub"
      ;;
  esac
}

cmd_secret_list_table() {
  local json stats now
  local total_cnt active_cnt total_in total_out total_bytes total_conn
  ensure_socket
  json="$(request GET /v1/secrets)"
  stats="$(request GET /v1/stats 2>/dev/null || true)"
  now="$(date +%s)"

  total_cnt="$(stats_json_field "$stats" secrets_total)"
  active_cnt="$(stats_json_field "$stats" secrets_active)"
  total_in="$(stats_json_field "$stats" bytes_in)"
  total_out="$(stats_json_field "$stats" bytes_out)"
  total_bytes="$(stats_json_field "$stats" bytes_total)"
  total_conn="$(stats_json_field "$stats" connections)"
  [[ -n "$total_cnt" ]] || total_cnt=0
  [[ -n "$active_cnt" ]] || active_cnt=0
  [[ -n "$total_in" ]] || total_in=0
  [[ -n "$total_out" ]] || total_out=0
  [[ -n "$total_bytes" ]] || total_bytes=$(( total_in + total_out ))
  [[ -n "$total_conn" ]] || total_conn=0

  printf 'TOTALS     users=%s active=%s in=%s out=%s total=%s conn=%s\n' \
    "$total_cnt" "$active_cnt" "$(fmt_bytes "$total_in")" "$(fmt_bytes "$total_out")" "$(fmt_bytes "$total_bytes")" "$total_conn"
  printf '%-10s %-8s %-8s %-20s %-10s %-10s %-10s %-6s %-32s %-14s %s\n' \
    "STATUS" "ENABLED" "ACTIVE" "ACTIVE_UNTIL(UTC)" "IN" "OUT" "TOTAL" "CONN" "SECRET" "LABEL" "LAST_IP"

  local rows row
  rows="$(secrets_json_rows "$json")"
  if [[ -z "$rows" ]]; then
    return 0
  fi

  while IFS= read -r row; do
    [[ -n "$row" ]] || continue
    local secret enabled active expires label until status color bytes_in bytes_out bytes_total connections last_ip
    secret="$(secret_row_field "$row" secret)"
    enabled="$(secret_row_field "$row" enabled)"
    active="$(secret_row_field "$row" active)"
    expires="$(secret_row_field "$row" expires)"
    label="$(secret_row_field "$row" label)"
    bytes_in="$(secret_row_field "$row" bytes_in)"
    bytes_out="$(secret_row_field "$row" bytes_out)"
    bytes_total="$(secret_row_field "$row" bytes_total)"
    connections="$(secret_row_field "$row" connections)"
    last_ip="$(secret_row_field "$row" last_ip)"
    [[ -n "$bytes_in" ]] || bytes_in=0
    [[ -n "$bytes_out" ]] || bytes_out=0
    [[ -n "$bytes_total" ]] || bytes_total=$(( bytes_in + bytes_out ))
    [[ -n "$connections" ]] || connections=0
    [[ -n "$last_ip" ]] || last_ip="-"
    until="$(iso_utc_from_unix "$expires")"
    status="INACTIVE"
    color="$C_YELLOW"
    if [[ "$active" == "true" ]]; then
      status="ACTIVE"
      color="$C_GREEN"
    elif [[ "$enabled" == "false" ]]; then
      status="DISABLED"
      color="$C_RED"
    elif [[ "$expires" =~ ^[0-9]+$ ]] && (( expires > 0 && now >= expires )); then
      status="EXPIRED"
      color="$C_YELLOW"
    fi
    printf '%-10s %-8s %-8s %-20s %-10s %-10s %-10s %-6s %-32s %-14s %s\n' \
      "$(paint "$color" "$status")" "$enabled" "$active" "$until" \
      "$(fmt_bytes "$bytes_in")" "$(fmt_bytes "$bytes_out")" "$(fmt_bytes "$bytes_total")" "$connections" \
      "$secret" "$label" "$last_ip"
  done <<<"$rows"
}

cmd_secret_stats() {
  local wanted="${1:-}"
  local json rows row found
  ensure_socket
  json="$(request GET /v1/secrets)"
  rows="$(secrets_json_rows "$json")"
  found=0

  printf '%-32s %-18s %-8s %-8s %-10s %-10s %-10s %-8s %-39s %-20s\n' \
    "SECRET" "LABEL" "ENABLED" "ACTIVE" "IN" "OUT" "TOTAL" "CONN" "LAST_IP" "ACTIVE_UNTIL(UTC)"

  while IFS= read -r row; do
    [[ -n "$row" ]] || continue
    local secret label enabled active expires bytes_in bytes_out bytes_total connections last_ip
    secret="$(secret_row_field "$row" secret)"
    [[ -n "$secret" ]] || continue
    if [[ -n "$wanted" && "${secret,,}" != "${wanted,,}" ]]; then
      continue
    fi
    label="$(secret_row_field "$row" label)"
    enabled="$(secret_row_field "$row" enabled)"
    active="$(secret_row_field "$row" active)"
    expires="$(secret_row_field "$row" expires)"
    bytes_in="$(secret_row_field "$row" bytes_in)"
    bytes_out="$(secret_row_field "$row" bytes_out)"
    bytes_total="$(secret_row_field "$row" bytes_total)"
    connections="$(secret_row_field "$row" connections)"
    last_ip="$(secret_row_field "$row" last_ip)"
    [[ -n "$bytes_in" ]] || bytes_in=0
    [[ -n "$bytes_out" ]] || bytes_out=0
    [[ -n "$bytes_total" ]] || bytes_total=$(( bytes_in + bytes_out ))
    [[ -n "$connections" ]] || connections=0
    [[ -n "$last_ip" ]] || last_ip="-"
    printf '%-32s %-18s %-8s %-8s %-10s %-10s %-10s %-8s %-39s %-20s\n' \
      "$secret" "$label" "$enabled" "$active" \
      "$(fmt_bytes "$bytes_in")" "$(fmt_bytes "$bytes_out")" "$(fmt_bytes "$bytes_total")" "$connections" "$last_ip" \
      "$(iso_utc_from_unix "$expires")"
    found=1
  done <<<"$rows"

  if [[ -n "$wanted" && "$found" -eq 0 ]]; then
    die "secret not found: $wanted"
  fi
}

cmd_secret_expire_disable() {
  local json now resp checked disabled
  ensure_socket
  now="$(date +%s)"

  # Fast path for newer runtime: one lock pass + one persist in daemon.
  resp="$(request POST /v1/secrets/expire_disable "{\"now\":$now}" 2>/dev/null || true)"
  if json_is_ok "$resp"; then
    checked="$(echo "$resp" | sed -n 's/.*"checked":\([0-9][0-9]*\).*/\1/p')"
    disabled="$(echo "$resp" | sed -n 's/.*"disabled":\([0-9][0-9]*\).*/\1/p')"
    checked="${checked:-0}"
    disabled="${disabled:-0}"
    if (( disabled > 0 )); then
      audit_log info "secret_disable_expired_batch checked=$checked disabled=$disabled now=$now"
    fi
    printf '{"ok":true,"checked":%d,"disabled":%d,"now":%s}\n' "$checked" "$disabled" "$now"
    return 0
  fi

  # Backward-compatible fallback for older runtimes (per-secret PATCH loop).
  json="$(request GET /v1/secrets)"
  disabled=0
  checked=0

  local rows row
  rows="$(secrets_json_rows "$json")"
  if [[ -n "$rows" ]]; then
    while IFS= read -r row; do
      [[ -n "$row" ]] || continue
      local secret enabled expires
      secret="$(secret_row_field "$row" secret)"
      enabled="$(secret_row_field "$row" enabled)"
      expires="$(secret_row_field "$row" expires)"
      (( checked += 1 ))
      if [[ "$enabled" == "true" && "$expires" =~ ^[0-9]+$ ]] && (( expires > 0 && now >= expires )); then
        if request PATCH "/v1/secrets/$secret/disable" >/dev/null 2>&1; then
          (( disabled += 1 ))
          audit_log info "secret_disable_expired secret=$secret expires=$expires"
        fi
      fi
    done <<<"$rows"
  fi

  printf '{"ok":true,"checked":%d,"disabled":%d,"now":%s}\n' "$checked" "$disabled" "$now"
}

cmd_secret_add() {
  local secret="$1"
  shift
  local label=""
  local expires="0"
  local enabled="true"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --label)
        label="${2:-}"; shift 2 ;;
      --expires)
        expires="${2:-}"; [[ "$expires" =~ ^[0-9]+$ ]] || die "expires must be unix timestamp"; shift 2 ;;
      --disabled)
        enabled="false"; shift ;;
      --enabled)
        enabled="true"; shift ;;
      *)
        die "Unknown option: $1"
        ;;
    esac
  done

  local payload
  payload="{\"secret\":\"$(json_escape "$secret")\",\"label\":\"$(json_escape "$label")\",\"expires\":$expires,\"enabled\":$enabled}"
  api_call_with_log POST /v1/secrets "$payload" \
    "secret_add secret=$secret label=$label expires=$expires enabled=$enabled" \
    "secret_add_failed secret=$secret label=$label"
}

cmd_secret_issue() {
  local label="${1:-}"
  [[ -n "$label" ]] || die "Usage: proxyctl secret issue <label> [--days N|--expires TS] [--prefix dd|plain|ee]"
  shift

  local days=""
  local expires="0"
  local prefix="$SECRET_PREFIX"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --days)
        days="${2:-}"; [[ "$days" =~ ^[0-9]+$ ]] || die "days must be integer"; shift 2 ;;
      --expires)
        expires="${2:-}"; [[ "$expires" =~ ^[0-9]+$ ]] || die "expires must be unix timestamp"; shift 2 ;;
      --prefix)
        prefix="${2:-}"; shift 2 ;;
      *)
        die "Unknown option: $1"
        ;;
    esac
  done

  if [[ -n "$days" ]]; then
    expires="$(( $(date +%s) + days * 86400 ))"
  fi

  local secret
  secret="$(rand_hex16)"
  cmd_secret_add "$secret" --label "$label" --expires "$expires" >/dev/null

  local host
  host="$PUBLIC_HOST"
  [[ -n "$host" ]] || host="$(detect_public_host)"
  local out_secret
  out_secret="$(link_secret "$secret" "$prefix")"
  local active_until=""
  if [[ "$expires" =~ ^[0-9]+$ ]] && (( expires > 0 )); then
    active_until="$(date -u -d "@$expires" '+%Y-%m-%dT%H:%M:%SZ' 2>/dev/null || true)"
  fi

  printf '{"ok":true,"secret":"%s","expires":%s,"active_until":"%s","link":"https://t.me/proxy?server=%s&port=%s&secret=%s"}\n' \
    "$secret" "$expires" "$active_until" "$host" "$CLIENT_PORT" "$out_secret"
  audit_log info "secret_issue secret=$secret label=$label expires=$expires prefix=$prefix"
}

cmd_secret_update() {
  local secret="${1:-}"
  shift || true
  ensure_socket
  require_hex32 "$secret" || die "Usage: proxyctl secret update <secret> [--label <label>] [--expires <unix_ts>] [--enable|--disable]"

  local label=""
  local has_label=0
  local expires=""
  local has_expires=0
  local enabled=""
  local has_enabled=0

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --label)
        label="${2:-}"; has_label=1; shift 2 ;;
      --expires)
        expires="${2:-}"; [[ "$expires" =~ ^[0-9]+$ ]] || die "expires must be unix timestamp"; has_expires=1; shift 2 ;;
      --enable)
        enabled="true"; has_enabled=1; shift ;;
      --disable)
        enabled="false"; has_enabled=1; shift ;;
      *)
        die "Unknown option: $1"
        ;;
    esac
  done
  (( has_label || has_expires || has_enabled )) || die "nothing to update"

  local payload='{'
  local sep=""
  if (( has_label )); then
    payload+="${sep}\"label\":\"$(json_escape "$label")\""
    sep=","
  fi
  if (( has_expires )); then
    payload+="${sep}\"expires\":$expires"
    sep=","
  fi
  if (( has_enabled )); then
    payload+="${sep}\"enabled\":$enabled"
  fi
  payload+='}'
  api_call_with_log PATCH "/v1/secrets/$secret" "$payload" \
    "secret_update secret=$secret" \
    "secret_update_failed secret=$secret"
}

cmd_secret_renew() {
  local secret="${1:-}"
  shift || true
  ensure_socket
  require_hex32 "$secret" || die "Usage: proxyctl secret renew <secret> [--days <n> | --expires <unix_ts>]"

  local days=""
  local expires=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --days)
        days="${2:-}"; [[ "$days" =~ ^[0-9]+$ ]] || die "days must be integer"; shift 2 ;;
      --expires)
        expires="${2:-}"; [[ "$expires" =~ ^[0-9]+$ ]] || die "expires must be unix timestamp"; shift 2 ;;
      *)
        die "Unknown option: $1"
        ;;
    esac
  done
  [[ -n "$days" || -n "$expires" ]] || days="30"
  [[ -n "$days" && -n "$expires" ]] && die "use either --days or --expires"

  local target_expires="$expires"
  if [[ -n "$days" ]]; then
    local now cur base json row
    now="$(date +%s)"
    json="$(request GET /v1/secrets)"
    row="$(secrets_json_rows "$json" | grep -m1 -i "\"secret\":\"${secret,,}\"" || true)"
    [[ -n "$row" ]] || die "secret not found: $secret"
    cur="$(secret_row_field "$row" expires)"
    [[ -n "$cur" ]] || cur=0
    if [[ "$cur" =~ ^[0-9]+$ ]] && (( cur > now )); then
      base="$cur"
    else
      base="$now"
    fi
    target_expires="$(( base + days * 86400 ))"
  fi

  local resp active_until
  resp="$(request PATCH "/v1/secrets/$secret" "{\"expires\":$target_expires,\"enabled\":true}")"
  if json_is_ok "$resp"; then
    active_until="$(iso_utc_from_unix "$target_expires")"
    printf '{"ok":true,"secret":"%s","expires":%s,"active_until":"%s"}\n' \
      "$secret" "$target_expires" "$active_until"
    audit_log info "secret_renew secret=$secret expires=$target_expires"
  else
    echo "$resp"
    audit_log warn "secret_renew_failed secret=$secret expires=$target_expires response=$(echo "$resp" | tr -d '\n')"
  fi
}

cmd_secret() {
  local sub="${1:-}"
  case "$sub" in
    list)
      local mode="${2:-}"
      if [[ "$mode" == "--table" ]]; then
        cmd_secret_list_table
      else
        api GET /v1/secrets
      fi
      ;;
    stats)
      local wanted="${2:-}"
      cmd_secret_stats "$wanted"
      ;;
    add)
      local secret="${2:-}"
      [[ -n "$secret" ]] || die "Usage: proxyctl secret add <secret> ..."
      shift 2
      cmd_secret_add "$secret" "$@"
      ;;
    issue)
      local label="${2:-}"
      [[ -n "$label" ]] || die "Usage: proxyctl secret issue <label> ..."
      shift 2
      cmd_secret_issue "$label" "$@"
      ;;
    update)
      local secret_upd="${2:-}"
      [[ -n "$secret_upd" ]] || die "Usage: proxyctl secret update <secret> ..."
      shift 2
      cmd_secret_update "$secret_upd" "$@"
      ;;
    renew)
      local secret_renew="${2:-}"
      [[ -n "$secret_renew" ]] || die "Usage: proxyctl secret renew <secret> ..."
      shift 2
      cmd_secret_renew "$secret_renew" "$@"
      ;;
    remove)
      local secret_rm="${2:-}"
      [[ -n "$secret_rm" ]] || die "Usage: proxyctl secret remove <secret>"
      api_call_with_log DELETE "/v1/secrets/$secret_rm" "" \
        "secret_remove secret=$secret_rm" \
        "secret_remove_failed secret=$secret_rm"
      ;;
    enable)
      local secret_en="${2:-}"
      [[ -n "$secret_en" ]] || die "Usage: proxyctl secret enable <secret>"
      api_call_with_log PATCH "/v1/secrets/$secret_en/enable" "" \
        "secret_enable secret=$secret_en" \
        "secret_enable_failed secret=$secret_en"
      ;;
    disable)
      local secret_dis="${2:-}"
      [[ -n "$secret_dis" ]] || die "Usage: proxyctl secret disable <secret>"
      api_call_with_log PATCH "/v1/secrets/$secret_dis/disable" "" \
        "secret_disable secret=$secret_dis" \
        "secret_disable_failed secret=$secret_dis"
      ;;
    expire-disable|sync-expired)
      cmd_secret_expire_disable
      ;;
    *)
      die "Unknown secret action: $sub"
      ;;
  esac
}

cmd_bot_ssh() {
  local sub="${1:-}"
  shift || true
  local resp=""
  case "$sub" in
    show)
      BOT_MODE=0
      bot_setup_exec --show "$@"
      ;;
    rotate-password)
      BOT_MODE=0
      resp="$(bot_setup_exec --regen-password "$@")"
      echo "$resp"
      if json_is_ok "$resp"; then
        audit_log info "bot_ssh_rotate_password args=$*"
      else
        audit_log warn "bot_ssh_rotate_password_failed args=$* response=$(echo "$resp" | tr -d '\n')"
      fi
      ;;
    set)
      BOT_MODE=0
      resp="$(bot_setup_exec "$@")"
      echo "$resp"
      if json_is_ok "$resp"; then
        audit_log info "bot_ssh_set args=$*"
      else
        audit_log warn "bot_ssh_set_failed args=$* response=$(echo "$resp" | tr -d '\n')"
      fi
      ;;
    allow-from)
      BOT_MODE=0
      resp="$(bot_setup_exec --keep-password "$@")"
      echo "$resp"
      if json_is_ok "$resp"; then
        audit_log info "bot_ssh_allow_from args=$*"
      else
        audit_log warn "bot_ssh_allow_from_failed args=$* response=$(echo "$resp" | tr -d '\n')"
      fi
      ;;
    *)
      die "Usage: proxyctl bot ssh show | rotate-password [opts] | set <opts> | allow-from <opts>"
      ;;
  esac
}

cmd_bot_api() {
  local sub="${1:-}"
  shift || true
  local resp=""
  case "$sub" in
    show)
      BOT_MODE=0
      bot_http_setup_exec --show "$@"
      ;;
    rotate-password)
      BOT_MODE=0
      resp="$(bot_http_setup_exec --regen-password "$@")"
      echo "$resp"
      if json_is_ok "$resp"; then
        audit_log info "bot_api_rotate_password args=$*"
      else
        audit_log warn "bot_api_rotate_password_failed args=$* response=$(echo "$resp" | tr -d '\n')"
      fi
      ;;
    rotate-key)
      BOT_MODE=0
      resp="$(bot_http_setup_exec --regen-api-key "$@")"
      echo "$resp"
      if json_is_ok "$resp"; then
        audit_log info "bot_api_rotate_key args=$*"
      else
        audit_log warn "bot_api_rotate_key_failed args=$* response=$(echo "$resp" | tr -d '\n')"
      fi
      ;;
    set)
      BOT_MODE=0
      resp="$(bot_http_setup_exec "$@")"
      echo "$resp"
      if json_is_ok "$resp"; then
        audit_log info "bot_api_set args=$*"
      else
        audit_log warn "bot_api_set_failed args=$* response=$(echo "$resp" | tr -d '\n')"
      fi
      ;;
    status)
      systemctl --no-pager --full status "$BOT_HTTP_SERVICE.service"
      ;;
    restart)
      require_root
      systemctl restart "$BOT_HTTP_SERVICE.service"
      ;;
    *)
      die "Usage: proxyctl bot api show | rotate-password [opts] | rotate-key [opts] | set <opts> | status | restart"
      ;;
  esac
}

cmd_bot() {
  BOT_MODE=1
  local sub="${1:-}"
  case "$sub" in
    health)
      cmd_health
      ;;
    issue)
      local label="${2:-}"
      [[ -n "$label" ]] || die "Usage: proxyctl bot issue <label> [--days N]"
      shift 2
      cmd_secret_issue "$label" "$@"
      ;;
    renew)
      local secrn="${2:-}"
      [[ -n "$secrn" ]] || die "Usage: proxyctl bot renew <secret> [--days N|--expires TS]"
      shift 2
      cmd_secret_renew "$secrn" "$@"
      ;;
    disable)
      local secd="${2:-}"
      [[ -n "$secd" ]] || die "Usage: proxyctl bot disable <secret>"
      api_call_with_log PATCH "/v1/secrets/$secd/disable" "" \
        "bot_secret_disable secret=$secd" \
        "bot_secret_disable_failed secret=$secd"
      ;;
    enable)
      local sece="${2:-}"
      [[ -n "$sece" ]] || die "Usage: proxyctl bot enable <secret>"
      api_call_with_log PATCH "/v1/secrets/$sece/enable" "" \
        "bot_secret_enable secret=$sece" \
        "bot_secret_enable_failed secret=$sece"
      ;;
    revoke|remove)
      local secr="${2:-}"
      [[ -n "$secr" ]] || die "Usage: proxyctl bot revoke <secret>"
      api_call_with_log DELETE "/v1/secrets/$secr" "" \
        "bot_secret_revoke secret=$secr" \
        "bot_secret_revoke_failed secret=$secr"
      ;;
    ssh)
      BOT_MODE=0
      shift
      cmd_bot_ssh "$@"
      ;;
    api)
      BOT_MODE=0
      shift
      cmd_bot_api "$@"
      ;;
    setup-password)
      BOT_MODE=0
      shift
      bot_setup_exec "$@"
      ;;
    *)
      die "Unknown bot action: $sub"
      ;;
  esac
}

run_safe() {
  if ! "$@"; then
    warn "Command failed: $*"
  fi
}

menu_header() {
  local snap active substate pid start_ts mem cpu listen host total active_secrets
  local stealth
  local tls_domain
  snap="$(collect_service_snapshot)"
  IFS='|' read -r active substate pid start_ts mem cpu listen host total active_secrets <<<"$snap"
  stealth="$(stealth_mode_name)"
  tls_domain="${TLS_DOMAIN:-off}"
  echo
  echo "=========== $(paint "$C_BOLD" "$BRAND_CONSOLE") ==========="
  echo "Runtime   : $(paint "$C_BOLD" "$BRAND_NAME") ($(paint_state "$active" "$substate"))"
  echo "Node      : $BRAND_RUNTIME_ID  PID: $(paint "$C_CYAN" "$pid")"
  echo "Inbound ID: $(paint "$C_CYAN" "$CURRENT_INBOUND")  service: $SERVICE_NAME"
  echo "Endpoint  : ${host:-unknown}:$(paint "$C_CYAN" "$CLIENT_PORT")  listening: $(paint_bool "$listen")"
  echo "Stealth   : $(paint "$C_CYAN" "$stealth")"
  echo "TLS Cover : $(paint "$C_CYAN" "$tls_domain")"
  echo "Users     : total=$(paint "$C_CYAN" "$total") active=$(paint "$C_CYAN" "$active_secrets")"
  echo "Started   : $start_ts (UTC)"
  echo "=================================================="
}

menu_bot_settings() {
  while true; do
    local cred host user pass allow
    cred="$(load_bot_credentials)"
    IFS='|' read -r host user pass allow <<<"$cred"
    user="${user:-mtproxybot}"
    echo
    echo "-------- $(paint "$C_BOLD" "Bulldog Bot SSH Settings") --------"
    run_safe cmd_bot_ssh show
    if [[ -z "$pass" ]]; then
      echo "$(paint "$C_YELLOW" "[NOTE]") saved password is empty/unknown; rotate to issue a new one."
    fi
    echo "1) Rotate bot password"
    echo "2) Change bot username/password"
    echo "3) Change allow-from IP/CIDR (keep current password)"
    echo "0) Back"
    printf "Select: "
    IFS= read -r bchoice || true
    case "$bchoice" in
      1)
        printf "Username [%s]: " "$user"
        IFS= read -r buser || true
        buser="${buser:-$user}"
        printf "Allow-from (empty=keep, any=clear): "
        IFS= read -r ballow || true
        local -a args
        args=(--user "$buser")
        if [[ "${ballow,,}" == "any" ]]; then
          args+=(--allow-any)
        elif [[ -n "$ballow" ]]; then
          args+=(--allow-from "$ballow")
        fi
        run_safe cmd_bot_ssh rotate-password "${args[@]}"
        ;;
      2)
        printf "New username [%s]: " "$user"
        IFS= read -r nuser || true
        nuser="${nuser:-$user}"
        printf "Password (empty=auto-generate): "
        IFS= read -r npass || true
        printf "Allow-from (empty=keep, any=clear): "
        IFS= read -r nallow || true
        local -a set_args
        set_args=(--user "$nuser")
        if [[ -n "$npass" ]]; then
          set_args+=(--password "$npass")
        fi
        if [[ "${nallow,,}" == "any" ]]; then
          set_args+=(--allow-any)
        elif [[ -n "$nallow" ]]; then
          set_args+=(--allow-from "$nallow")
        fi
        run_safe cmd_bot_ssh set "${set_args[@]}"
        ;;
      3)
        printf "Username [%s]: " "$user"
        IFS= read -r auser || true
        auser="${auser:-$user}"
        printf "New allow-from (CIDR/IP or any): "
        IFS= read -r aallow || true
        if [[ -z "$aallow" ]]; then
          warn "allow-from value is required"
          continue
        fi
        local -a allow_args
        allow_args=(--user "$auser")
        if [[ "${aallow,,}" == "any" ]]; then
          allow_args+=(--allow-any)
        else
          allow_args+=(--allow-from "$aallow")
        fi
        run_safe cmd_bot_ssh allow-from "${allow_args[@]}"
        ;;
      0)
        return 0
        ;;
      *)
        warn "Unknown option"
        ;;
    esac
    echo
    printf "Press Enter to continue... "
    IFS= read -r _ || true
  done
}

menu_bot_http_settings() {
  while true; do
    local cred host user pass allow api_key base_path port listen key_short
    cred="$(load_bot_http_credentials)"
    IFS='|' read -r host user pass allow api_key base_path port listen <<<"$cred"
    user="${user:-botapi}"
    port="${port:-9443}"
    base_path="${base_path:-/bot}"
    listen="${listen:-0.0.0.0}"
    key_short="${api_key:0:12}"
    echo
    echo "-------- $(paint "$C_BOLD" "Bulldog Bot HTTP API Settings") --------"
    run_safe cmd_bot_api show
    if [[ -z "$pass" ]]; then
      echo "$(paint "$C_YELLOW" "[NOTE]") saved password is empty/unknown; rotate to issue a new one."
    fi
    if [[ -n "$api_key" ]]; then
      echo "api_key_prefix: ${key_short}..."
    fi
    echo "1) Rotate API password"
    echo "2) Rotate API key"
    echo "3) Change API user/base-path/port/allow-from"
    echo "4) Show API service status"
    echo "5) Restart API service"
    echo "0) Back"
    printf "Select: "
    IFS= read -r bchoice || true
    case "$bchoice" in
      1)
        printf "Username [%s]: " "$user"
        IFS= read -r auser || true
        auser="${auser:-$user}"
        printf "Allow-from (empty=keep, any=clear): "
        IFS= read -r aallow || true
        local -a args
        args=(--user "$auser")
        if [[ "${aallow,,}" == "any" ]]; then
          args+=(--allow-any)
        elif [[ -n "$aallow" ]]; then
          args+=(--allow-from "$aallow")
        fi
        run_safe cmd_bot_api rotate-password "${args[@]}"
        ;;
      2)
        run_safe cmd_bot_api rotate-key
        ;;
      3)
        printf "Username [%s]: " "$user"
        IFS= read -r nuser || true
        nuser="${nuser:-$user}"
        printf "Password (empty=keep current): "
        IFS= read -r npass || true
        printf "Port [%s]: " "$port"
        IFS= read -r nport || true
        nport="${nport:-$port}"
        printf "Base path [%s]: " "$base_path"
        IFS= read -r npath || true
        npath="${npath:-$base_path}"
        printf "Listen address [%s]: " "$listen"
        IFS= read -r nlisten || true
        nlisten="${nlisten:-$listen}"
        printf "Allow-from (empty=keep, any=clear): "
        IFS= read -r nallow || true
        local -a set_args
        set_args=(--user "$nuser" --port "$nport" --base-path "$npath" --listen "$nlisten")
        if [[ -n "$npass" ]]; then
          set_args+=(--password "$npass")
        fi
        if [[ "${nallow,,}" == "any" ]]; then
          set_args+=(--allow-any)
        elif [[ -n "$nallow" ]]; then
          set_args+=(--allow-from "$nallow")
        fi
        run_safe cmd_bot_api set "${set_args[@]}"
        ;;
      4)
        run_safe cmd_bot_api status
        ;;
      5)
        run_safe cmd_bot_api restart
        ;;
      0)
        return 0
        ;;
      *)
        warn "Unknown option"
        ;;
    esac
    echo
    printf "Press Enter to continue... "
    IFS= read -r _ || true
  done
}

menu_stealth_settings() {
  while true; do
    local current domain
    current="$(stealth_mode_name)"
    domain="${TLS_DOMAIN:-off}"
    echo
    echo "-------- $(paint "$C_BOLD" "Bulldog Stealth Settings") --------"
    echo "Current mode: $(paint "$C_CYAN" "$current")"
    echo "TLS cover domain: $(paint "$C_CYAN" "$domain")"
    echo "1) Standard (dd)"
    echo "2) Max camouflage (ee)"
    echo "3) Compatibility (plain)"
    echo "4) Set custom mode (plain/dd/ee)"
    echo "5) Set TLS cover domain (example: www.google.com)"
    echo "6) Disable TLS cover domain"
    echo "7) Explain modes"
    echo "0) Back"
    printf "Select: "
    IFS= read -r sch || true
    case "$sch" in
      1)
        run_safe cmd_config_set stealth-preset standard
        ;;
      2)
        run_safe cmd_config_set stealth-preset max-camouflage
        ;;
      3)
        run_safe cmd_config_set stealth-preset compatibility
        ;;
      4)
        printf "Mode (plain/dd/ee): "
        IFS= read -r mode || true
        [[ -n "$mode" ]] && run_safe cmd_config_set stealth-mode "$mode"
        ;;
      5)
        printf "Domain (example: www.google.com): "
        IFS= read -r d || true
        [[ -n "$d" ]] && run_safe cmd_config_set tls-domain "$d"
        ;;
      6)
        run_safe cmd_config_set tls-domain off
        ;;
      7)
        print_stealth_explain
        ;;
      0)
        return 0
        ;;
      *)
        warn "Unknown option"
        ;;
    esac
    echo
    printf "Press Enter to continue... "
    IFS= read -r _ || true
  done
}

menu_inbound_edit() {
  local target="${1:-}"
  [[ -n "$target" ]] || return 1
  local envf cur_port cur_stats cur_host cur_mode cur_tls
  envf="$(inbound_env_file "$target")"
  cur_port="$(inbound_env_value "$envf" CLIENT_PORT "443")"
  cur_stats="$(inbound_env_value "$envf" STATS_PORT "8888")"
  cur_host="$(inbound_env_value "$envf" PUBLIC_HOST "${PUBLIC_HOST:-}")"
  cur_mode="$(inbound_env_value "$envf" SECRET_PREFIX "dd")"
  cur_tls="$(inbound_env_value "$envf" TLS_DOMAIN "")"

  echo
  echo "Editing inbound: $(paint "$C_CYAN" "$target")"
  echo "Leave field empty to keep current value."

  printf "Client port [%s]: " "$cur_port"
  IFS= read -r new_port || true
  if [[ -n "$new_port" ]]; then
    run_safe run_for_inbound "$target" config set client-port "$new_port"
  fi

  printf "Stats port [%s]: " "$cur_stats"
  IFS= read -r new_stats || true
  if [[ -n "$new_stats" ]]; then
    run_safe run_for_inbound "$target" config set stats-port "$new_stats"
  fi

  printf "Public host [%s]: " "$cur_host"
  IFS= read -r new_host || true
  if [[ -n "$new_host" ]]; then
    run_safe run_for_inbound "$target" config set public-host "$new_host"
  fi

  printf "Stealth mode plain/dd/ee [%s]: " "$cur_mode"
  IFS= read -r new_mode || true
  if [[ -n "$new_mode" ]]; then
    run_safe run_for_inbound "$target" config set stealth-mode "$new_mode"
  fi

  printf "TLS domain [%s] (use 'off' to disable): " "${cur_tls:-off}"
  IFS= read -r new_tls || true
  if [[ -n "$new_tls" ]]; then
    run_safe run_for_inbound "$target" config set tls-domain "$new_tls"
  fi

  printf "Rotate bootstrap secret now? [y/N]: "
  IFS= read -r rotate_boot || true
    case "${rotate_boot,,}" in
    y|yes)
      run_safe run_for_inbound "$target" config set bootstrap-secret "$(rand_bootstrap_secret)"
      ;;
    *)
      ;;
  esac
}

menu_inbound_create() {
  echo
  echo "-------- $(paint "$C_BOLD" "Create New Inbound") --------"
  echo "Inbound ID will be assigned automatically (next free ID: 2, 3, ...)."
  local port stats host mode tls
  printf "Client port: "
  IFS= read -r port || true
  [[ -n "$port" ]] || { warn "port is required"; return 1; }
  printf "Stats port [8888]: "
  IFS= read -r stats || true
  stats="${stats:-8888}"
  printf "Public host [%s]: " "${PUBLIC_HOST:-$(detect_public_host)}"
  IFS= read -r host || true
  host="${host:-${PUBLIC_HOST:-$(detect_public_host)}}"
  printf "Stealth mode (plain/dd/ee) [dd]: "
  IFS= read -r mode || true
  mode="${mode:-dd}"
  printf "TLS domain (empty=off): "
  IFS= read -r tls || true
  run_safe cmd_inbound create --port "$port" --stats-port "$stats" --public-host "$host" --mode "$mode" --tls-domain "${tls:-off}"
}

menu_inbound_manage() {
  while true; do
    echo
    echo "-------- $(paint "$C_BOLD" "Bulldog Inbounds") --------"
    run_safe cmd_inbound list --table
    echo "1) Open inbound console"
    echo "2) Create inbound"
    echo "3) Edit inbound settings"
    echo "4) Remove inbound"
    echo "0) Back"
    printf "Select: "
    IFS= read -r ich || true
    case "$ich" in
      1)
        local open_name=""
        open_name="$(pick_inbound_interactive "Select inbound ID to open: ")" || { continue; }
        exec_for_inbound "$open_name" console
        ;;
      2)
        menu_inbound_create
        ;;
      3)
        local edit_name=""
        edit_name="$(pick_inbound_interactive "Select inbound ID to edit: ")" || { continue; }
        run_safe menu_inbound_edit "$edit_name"
        ;;
      4)
        local rm_name=""
        rm_name="$(pick_inbound_interactive "Select inbound ID to remove: ")" || { continue; }
        if [[ "$rm_name" == "1" ]]; then
          warn "inbound ID 1 cannot be removed"
          continue
        fi
        run_safe cmd_inbound remove "$rm_name"
        ;;
      0)
        return 0
        ;;
      *)
        warn "Unknown option"
        ;;
    esac
    echo
    printf "Press Enter to continue... "
    IFS= read -r _ || true
  done
}

console_entrypoint() {
  local total
  total="$(inbound_count)"
  if [[ "$INBOUND_SELECTED" == "1" ]] || (( total <= 1 )); then
    menu_cmd
    return 0
  fi

  while true; do
    echo
    echo "======== $(paint "$C_BOLD" "Bulldog Inbound Selector") ========"
    run_safe cmd_inbound list --table
    echo "1) Open inbound console"
    echo "2) Manage inbounds"
    echo "0) Exit"
    printf "Select: "
    IFS= read -r sel || true
    case "$sel" in
      1)
        local target=""
        target="$(pick_inbound_interactive "Select inbound ID to open: ")" || { continue; }
        exec_for_inbound "$target" console
        ;;
      2)
        menu_inbound_manage
        ;;
      0)
        return 0
        ;;
      *)
        warn "Unknown option"
        ;;
    esac
  done
}

menu_cmd() {
  while true; do
    menu_header
    echo "[Runtime]"
    echo "1) Runtime overview"
    echo "2) Health probe (JSON)"
    echo "3) Restart runtime"
    echo "4) Full systemd runtime status"
    echo "5) Runtime logs (last 120)"
    echo "6) Runtime logs (live)"
    echo "7) Update runtime from repo"
    echo
    echo "[Client Access]"
    echo "8) Show client links (this inbound)"
    echo "9) Change client port (restart)"
    echo "10) Rotate bootstrap secret"
    echo "11) Change public host"
    echo "12) Stealth presets / mode"
    echo
    echo "[Users / Subscriptions]"
    echo "13) List users (table)"
    echo "14) Issue user access (secret + link)"
    echo "15) Suspend user access"
    echo "16) Resume user access"
    echo "17) Revoke user access"
    echo "18) Sync expired users -> disabled"
    echo
    echo "[Bot Integration]"
    echo "19) Bot SSH settings (login/password/allow-from)"
    echo "20) Bot HTTP API settings (host/base-path/login/password)"
    echo
    echo "[Inbounds]"
    echo "21) Inbounds list/manage"
    echo "22) Switch to another inbound"
    echo "23) Create new inbound"
    echo "24) Edit inbound settings"
    echo "25) Remove inbound"
    echo "0) Exit"
    printf "Select: "
    IFS= read -r choice || true

    case "$choice" in
      1)
        run_safe print_service_summary
        ;;
      2)
        run_safe cmd_health
        ;;
      3)
        run_safe service_cmd restart
        ;;
      4)
        run_safe service_cmd status --full
        ;;
      5)
        run_safe service_cmd logs
        ;;
      6)
        run_safe service_cmd logs-live
        ;;
      7)
        run_safe service_cmd update
        ;;
      8)
        run_safe cmd_link
        ;;
      9)
        printf "New client port: "
        IFS= read -r newport || true
        [[ -n "$newport" ]] && run_safe cmd_config_set client-port "$newport"
        ;;
      10)
        printf "New bootstrap secret (32 hex): "
        IFS= read -r news || true
        [[ -n "$news" ]] && run_safe cmd_config_set bootstrap-secret "$news"
        ;;
      11)
        printf "New public host/IP: "
        IFS= read -r newhost || true
        [[ -n "$newhost" ]] && run_safe cmd_config_set public-host "$newhost"
        ;;
      12)
        run_safe menu_stealth_settings
        ;;
      13)
        run_safe cmd_secret list --table
        ;;
      14)
        printf "Label: "
        IFS= read -r label || true
        [[ -n "$label" ]] || { warn "label is required"; continue; }
        printf "Days active (empty for no expiry): "
        IFS= read -r days || true
        if [[ -n "$days" ]]; then
          run_safe cmd_secret issue "$label" --days "$days"
        else
          run_safe cmd_secret issue "$label"
        fi
        ;;
      15)
        printf "Secret to suspend: "
        IFS= read -r secd || true
        [[ -n "$secd" ]] && run_safe cmd_secret disable "$secd"
        ;;
      16)
        printf "Secret to resume: "
        IFS= read -r sece || true
        [[ -n "$sece" ]] && run_safe cmd_secret enable "$sece"
        ;;
      17)
        printf "Secret to revoke/remove: "
        IFS= read -r secr || true
        [[ -n "$secr" ]] && run_safe cmd_secret remove "$secr"
        ;;
      18)
        run_safe cmd_secret expire-disable
        ;;
      19)
        run_safe menu_bot_settings
        ;;
      20)
        run_safe menu_bot_http_settings
        ;;
      21)
        run_safe menu_inbound_manage
        ;;
      22)
        local switch_name=""
        switch_name="$(pick_inbound_interactive "Select inbound ID to open: ")" || { continue; }
        exec_for_inbound "$switch_name" console
        ;;
      23)
        run_safe menu_inbound_create
        ;;
      24)
        local edit_name=""
        edit_name="$(pick_inbound_interactive "Select inbound ID to edit: ")" || { continue; }
        run_safe menu_inbound_edit "$edit_name"
        ;;
      25)
        local rm_name=""
        rm_name="$(pick_inbound_interactive "Select inbound ID to remove: ")" || { continue; }
        if [[ "$rm_name" == "1" ]]; then
          warn "inbound ID 1 cannot be removed"
          continue
        fi
        run_safe cmd_inbound remove "$rm_name"
        ;;
      0)
        exit 0
        ;;
      *)
        warn "Unknown option"
        ;;
    esac

    echo
    printf "Press Enter to continue... "
    IFS= read -r _ || true
  done
}

cmd="${1:-}"
case "$cmd" in
  status)
    cmd_status
    ;;
  stats)
    cmd_stats
    ;;
  health)
    cmd_health
    ;;
  link)
    shift
    cmd_link "$@"
    ;;
  service|runtime)
    sub="${2:-}"
    [[ -n "$sub" ]] || die "Usage: proxyctl runtime status [--full|--json] | start|stop|restart|logs|logs-live|update"
    opt="${3:-}"
    service_cmd "$sub" "$opt"
    ;;
  config)
    sub="${2:-}"
    case "$sub" in
      show)
        cmd_config_show
        ;;
      set)
        shift 2
        cmd_config_set "$@"
        ;;
      *)
        die "Usage: proxyctl config show | proxyctl config set <key> <value>"
        ;;
    esac
    ;;
  inbound)
    shift
    cmd_inbound "$@"
    ;;
  secret)
    shift
    cmd_secret "$@"
    ;;
  bot)
    shift
    cmd_bot "$@"
    ;;
  menu|console)
    console_entrypoint
    ;;
  *)
    usage
    exit 1
    ;;
esac
